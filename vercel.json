{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ms618.nl" }],
      "destination": "https://www.ms618.nl/$1",
      "permanent": true
    },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/en/home", "destination": "/en/", "permanent": true },
    { "source": "/nl/(.*)", "destination": "/$1", "permanent": true },
    { "source": "/en/voorwaarden", "destination": "/en/terms/", "permanent": true },
    { "source": "/services", "destination": "/diensten/", "permanent": true },
    { "source": "/services/(.*)", "destination": "/diensten/$1", "permanent": true },
    { "source": "/about", "destination": "/over-ons/", "permanent": true },
    { "source": "/about/(.*)", "destination": "/over-ons/$1", "permanent": true },
    { "source": "/cases/(b2b-leadgeneratie|saas-organisch-verkeer|e-commerce-conversie)", "destination": "/cases/", "permanent": true },
    { "source": "/cases/(b2b-leadgeneratie|saas-organisch-verkeer|e-commerce-conversie)/(.*)", "destination": "/cases/", "permanent": true },
    { "source": "/en/cases/(b2b-leadgeneratie|saas-organisch-verkeer|e-commerce-conversie)", "destination": "/en/cases/", "permanent": true },
    { "source": "/en/cases/(b2b-leadgeneratie|saas-organisch-verkeer|e-commerce-conversie)/(.*)", "destination": "/en/cases/", "permanent": true },
    { "source": "/en/services/website-laten-maken", "destination": "/en/services/website-development/", "permanent": true },
    { "source": "/en/services/website-laten-maken/(.*)", "destination": "/en/services/website-development/$1", "permanent": true },
    { "source": "/en/services/website-optimalisatie", "destination": "/en/services/website-optimization/", "permanent": true },
    { "source": "/en/services/website-optimalisatie/(.*)", "destination": "/en/services/website-optimization/$1", "permanent": true },
    { "source": "/en/services/seo-strategie", "destination": "/en/services/seo-strategy/", "permanent": true },
    { "source": "/en/services/seo-strategie/(.*)", "destination": "/en/services/seo-strategy/$1", "permanent": true },
    { "source": "/en/services/ai-strategie", "destination": "/en/services/ai-strategy/", "permanent": true },
    { "source": "/en/services/ai-strategie/(.*)", "destination": "/en/services/ai-strategy/$1", "permanent": true },
    { "source": "/en/services/geo-optimalisatie", "destination": "/en/services/geo-optimization/", "permanent": true },
    { "source": "/en/services/geo-optimalisatie/(.*)", "destination": "/en/services/geo-optimization/$1", "permanent": true },
    { "source": "/en/blog/zoekintentie-begrijpen", "destination": "/en/blog/understanding-search-intent/", "permanent": true },
    { "source": "/en/blog/zoekintentie-begrijpen/(.*)", "destination": "/en/blog/understanding-search-intent/$1", "permanent": true },
    { "source": "/en/blog/ai-en-seo-2026", "destination": "/en/blog/ai-and-seo-2026/", "permanent": true },
    { "source": "/en/blog/ai-en-seo-2026/(.*)", "destination": "/en/blog/ai-and-seo-2026/$1", "permanent": true },
    { "source": "/en/blog/content-strategie-b2b", "destination": "/en/blog/b2b-content-strategy/", "permanent": true },
    { "source": "/en/blog/content-strategie-b2b/(.*)", "destination": "/en/blog/b2b-content-strategy/$1", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}
