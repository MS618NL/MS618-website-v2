{
  "$ref": "#/definitions/local",
  "definitions": {
    "local": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "seoTitle": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "maxLength": 160
        },
        "ogImage": {
          "type": "string"
        },
        "noindex": {
          "type": "boolean",
          "default": false
        },
        "order": {
          "type": "number",
          "default": 99
        },
        "region": {
          "type": "string",
          "default": "Friesland"
        },
        "navLabel": {
          "type": "string"
        },
        "faq": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": {
                "type": "string"
              },
              "answer": {
                "type": "string"
              }
            },
            "required": [
              "question",
              "answer"
            ],
            "additionalProperties": false
          }
        },
        "updatedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}