---
import Page from '@/layouts/Page.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTA from '@/components/CTA.astro';
import { getCollection } from 'astro:content';
import site from '@/data/site.json';

const services = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order);

const breadcrumbs = [
  { name: 'Home', item: site.url },
  { name: 'Services' },
];
---

<Page
  title="Services"
  seoTitle="Digitale Marketing Services voor B2B — MS618"
  description="Strategie, technologie en uitvoering. Alles wat je nodig hebt om te groeien, niets wat je niet nodig hebt."
  breadcrumbs={breadcrumbs}
>
  <div class="services-listing">
    <div class="container">
      <header class="page-header">
        <h1>Services</h1>
        <p class="lead">Strategie, technologie en uitvoering. Alles wat je nodig hebt om te groeien, niets wat je niet nodig hebt.</p>
      </header>

      <section class="services-intro">
        <div class="intro-content">
          <h2>Onze aanpak</h2>
          <p class="intro-lead">Elk project begint met één vraag: wat heeft jouw bedrijf nodig om te groeien? Van daaruit bouwen we een systeem dat past bij jouw situatie. Geen standaardpakket. Geen overbodige lagen.</p>
          
          <div class="approach-grid">
            <div class="approach-item">
              <span class="approach-number">01</span>
              <div>
                <strong>Strategie & AI-implementatie</strong>
                <p>We analyseren je markt, je concurrenten en je kansen. Bepalen waar AI je bedrijf sterker maakt en implementeren het. Van marketing tot werkprocessen, van content tot klantcommunicatie.</p>
              </div>
            </div>
            <div class="approach-item">
              <span class="approach-number">02</span>
              <div>
                <strong>Zichtbaarheid & vindbaarheid</strong>
                <p>Gevonden worden waar het ertoe doet. SEO, Google Ads, AI-vindbaarheid, LinkedIn. Niet overal aanwezig zijn, maar op de juiste plekken.</p>
              </div>
            </div>
            <div class="approach-item">
              <span class="approach-number">03</span>
              <div>
                <strong>Websites, design & merkbeleving</strong>
                <p>Heldere websites die vertrouwen wekken. Visuele identiteit die klopt. Offline en online consistent, van visitekaartje tot campagne.</p>
              </div>
            </div>
            <div class="approach-item">
              <span class="approach-number">04</span>
              <div>
                <strong>Content & communicatie</strong>
                <p>Teksten, beelden en campagnes die jouw expertise tonen. Geen volume, maar content die werkt. Geschreven door mensen, versterkt door AI.</p>
              </div>
            </div>
            <div class="approach-item">
              <span class="approach-number">05</span>
              <div>
                <strong>Groei & optimalisatie</strong>
                <p>Leads binnenhalen, klanten behouden, continu verbeteren op basis van data. Wat niet werkt, stoppen we. Wat werkt, verdubbelen we.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="services-grid-section">
        <h2>Alle services</h2>
        <div class="services-grid">
          {services.map((service) => (
            <ServiceCard
              title={service.data.title}
              description={service.data.description}
              slug={service.id}
              icon={service.data.icon}
            />
          ))}
        </div>
      </section>
    </div>

    <CTA
      headline="Niet zeker welke service past?"
      body="Plan een kennismakingsgesprek. Wij luisteren naar jouw uitdaging en adviseren welke aanpak het meest effectief is voor jouw situatie."
    />
  </div>
</Page>

<style>
  .services-listing {
    padding-top: 4rem;
  }

  .page-header {
    padding: 3rem 0 3rem;
    border-bottom: 1px solid oklch(0.15 0 0);
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 0.75rem;
  }

  .lead {
    font-size: 1.125rem;
    color: oklch(0.55 0 0);
    line-height: 1.7;
    max-width: 640px;
  }

  .services-intro {
    margin-bottom: 5rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .intro-content h2 {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1rem;
  }

  .intro-lead {
    font-size: 1.0625rem;
    color: oklch(0.55 0 0);
    line-height: 1.75;
    max-width: 720px;
    margin-bottom: 2rem;
  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem 2.5rem;
  }

  .approach-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .approach-number {
    flex-shrink: 0;
    font-size: 0.8125rem;
    font-weight: 600;
    color: oklch(0.65 0.15 250);
    padding-top: 0.1rem;
  }

  .approach-item strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.92 0 0);
    margin-bottom: 0.25rem;
  }

  .approach-item p {
    font-size: 0.875rem;
    color: oklch(0.5 0 0);
    line-height: 1.6;
  }

  .services-grid-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 6rem;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .approach-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
