---
import Page from '@/layouts/Page.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTA from '@/components/CTA.astro';
import { getCollection } from 'astro:content';
import site from '@/data/site.json';

const services = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order);

const breadcrumbs = [
  { name: 'Home', item: site.url },
  { name: 'Services' },
];
---

<Page
  title="Services"
  seoTitle="Digitale Marketing Services voor B2B — MS618"
  description="Van SEO-strategie tot performance advertising: MS618 biedt een volledig spectrum aan digitale groeisservices voor ambitieuze B2B-organisaties."
  breadcrumbs={breadcrumbs}
>
  <div class="services-listing">
    <div class="container">
      <header class="page-header">
        <h1>Services</h1>
        <p class="lead">Wij bieden een volledig spectrum aan digitale groeisservices — altijd vertrekkend vanuit strategie, altijd gemeten op zakelijk resultaat.</p>
      </header>

      <section class="services-intro">
        <div class="intro-grid">
          <div>
            <h2>De ALANO-methodiek</h2>
            <p>Al onze services zijn gebouwd rondom onze ALANO-methodiek: Attract, Lead, Activate, Nurture, Optimize. Elke fase is gekoppeld aan meetbare doelstellingen en sluit aan op de volgende. Zo werken alle onderdelen samen aan één doel: duurzame, schaalbare groei.</p>
            <p>Wij werken niet met losse tactieken. Elk project start met een strategische basis — en elke actie is terug te leiden naar een zakelijk resultaat.</p>
          </div>
          <div class="intro-principles">
            <div class="principle">
              <span class="p-icon">A</span>
              <div>
                <strong>Attract</strong>
                <span>Zichtbaarheid bij de juiste doelgroep via SEO, content en advertising</span>
              </div>
            </div>
            <div class="principle">
              <span class="p-icon">L</span>
              <div>
                <strong>Lead</strong>
                <span>Bezoekers omzetten naar gekwalificeerde leads</span>
              </div>
            </div>
            <div class="principle">
              <span class="p-icon">A</span>
              <div>
                <strong>Activate</strong>
                <span>Leads activeren naar klanten via nurturing en sales enablement</span>
              </div>
            </div>
            <div class="principle">
              <span class="p-icon">N</span>
              <div>
                <strong>Nurture</strong>
                <span>Klanten behouden en uitbouwen via loyaliteitsstrategieën</span>
              </div>
            </div>
            <div class="principle">
              <span class="p-icon">O</span>
              <div>
                <strong>Optimize</strong>
                <span>Continu verbeteren op basis van data en resultaten</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="services-grid-section">
        <h2>Alle services</h2>
        <div class="services-grid">
          {services.map((service) => (
            <ServiceCard
              title={service.data.title}
              description={service.data.description}
              slug={service.id}
              icon={service.data.icon}
            />
          ))}
        </div>
      </section>
    </div>

    <CTA
      headline="Niet zeker welke service past?"
      body="Plan een kennismakingsgesprek. Wij luisteren naar jouw uitdaging en adviseren welke aanpak het meest effectief is voor jouw situatie."
    />
  </div>
</Page>

<style>
  .services-listing {
    padding-top: 4rem;
  }

  .page-header {
    padding: 3rem 0 3rem;
    border-bottom: 1px solid oklch(0.15 0 0);
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 0.75rem;
  }

  .lead {
    font-size: 1.125rem;
    color: oklch(0.55 0 0);
    line-height: 1.7;
    max-width: 640px;
  }

  .services-intro {
    margin-bottom: 5rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .intro-grid h2 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1rem;
  }

  .intro-grid p {
    color: oklch(0.5 0 0);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .intro-principles {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .principle {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .p-icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid oklch(0.25 0 0);
    font-size: 0.75rem;
    font-weight: 700;
    color: oklch(0.65 0.2 250);
  }

  .principle strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.82 0 0);
    margin-bottom: 0.15rem;
  }

  .principle span {
    font-size: 0.875rem;
    color: oklch(0.45 0 0);
    line-height: 1.5;
  }

  .services-grid-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 6rem;
  }

  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
