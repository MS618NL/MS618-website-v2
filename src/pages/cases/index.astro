---
import Page from '@/layouts/Page.astro';
import CaseCard from '@/components/CaseCard.astro';
import CTA from '@/components/CTA.astro';
import { getCollection } from 'astro:content';
import site from '@/data/site.json';

const cases = (await getCollection('cases'))
  .filter((c) => !c.data.noindex)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const breadcrumbs = [
  { name: 'Home', item: site.url },
  { name: 'Cases' },
];
---

<Page
  title="Cases"
  seoTitle="Klantcases — Hoe MS618 B2B-groei realiseert | MS618"
  description="Voorbeeldcases die laten zien hoe MS618 B2B-bedrijven helpt groeien met SEO, content en advertising. Concrete aanpak, eerlijke verwachtingen."
  breadcrumbs={breadcrumbs}
>
  <div class="cases-listing">
    <div class="container">
      <header class="page-header">
        <h1>Cases</h1>
        <p class="lead">Concrete aanpak voor concrete uitdagingen. Wij laten ons werk spreken, eerlijk en zonder opsmuk.</p>
      </header>

      <section class="cases-intro">
        <p>Onderstaande cases zijn voorbeeldcases op basis van werkelijke projectpatronen. Tijdens een kennismakingsgesprek gaan wij dieper in op specifieke projecten die relevant zijn voor jouw situatie.</p>
      </section>

      <div class="cases-grid">
        {cases.map((c) => (
          <CaseCard
            title={c.data.title}
            description={c.data.description}
            slug={c.id}
            client={c.data.client}
            service={c.data.service}
            result={c.data.result}
          />
        ))}
      </div>

      <div class="cases-disclaimer">
        <p>Dit zijn voorbeeldcases op basis van werkelijke resultaten. Volledige cases met achtergrond en aanpak volgen binnenkort. Resultaten variëren per situatie, markt en startpunt.</p>
      </div>
    </div>

    <CTA
      headline="Herken je de uitdaging?"
      body="Plan een gesprek. Wij bespreken jouw specifieke situatie en vertellen hoe een vergelijkbare aanpak voor jou zou kunnen werken."
    />
  </div>
</Page>

<style>
  .cases-listing {
    padding-top: 4rem;
  }

  .page-header {
    padding: 3rem 0 3rem;
    border-bottom: 1px solid oklch(0.15 0 0);
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 0.75rem;
  }

  .lead {
    font-size: 1.125rem;
    color: oklch(0.68 0 0);
    line-height: 1.7;
    max-width: 640px;
  }

  .cases-intro {
    margin-bottom: 2.5rem;
  }

  .cases-intro p {
    font-size: 0.9375rem;
    color: oklch(0.65 0 0);
    line-height: 1.7;
    padding: 1rem 1.25rem;
    border: 1px solid oklch(0.18 0 0);
    background: oklch(0.11 0 0);
    max-width: 640px;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .cases-disclaimer {
    margin-bottom: 5rem;
  }

  .cases-disclaimer p {
    font-size: 0.8125rem;
    color: oklch(0.63 0 0);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .cases-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
