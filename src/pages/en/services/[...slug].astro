---
import Post from '@/layouts/Post.astro';
import CTA from '@/components/CTA.astro';
import CaseCard from '@/components/CaseCard.astro';
import { getCollection, render } from 'astro:content';
import { buildServicePiece, buildFaqPiece } from '@/utils/schema';
import { canonicalUrl } from '@/utils/seo';
import site from '@/data/site.json';

export async function getStaticPaths() {
  const services = await getCollection('services-en');
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

// Get related cases for this service
const allCases = await getCollection('cases-en');
const relatedCases = allCases
  .filter((c) => c.data.relatedService === service.id)
  .slice(0, 3);

const pageUrl = canonicalUrl(`/en/services/${service.id}/`);
const breadcrumbs = [
  { name: 'Home', item: site.url + '/en/' },
  { name: 'Services', item: `${site.url}/en/services/` },
  { name: service.data.title },
];

const faqs = service.data.faq ?? [];
const extraSchema = [
  buildServicePiece(pageUrl, service.data.title, service.data.description),
  ...(faqs.length > 0 ? [buildFaqPiece(pageUrl, faqs)] : []),
];
---

<Post
  title={service.data.title}
  seoTitle={service.data.seoTitle}
  description={service.data.description}
  ogImage={service.data.ogImage}
  ogType="website"
  includeArticleSchema={false}
  noindex={service.data.noindex}
  publishDate={service.data.updatedDate ?? new Date()}
  updatedDate={service.data.updatedDate}
  breadcrumbs={breadcrumbs}
  extraSchema={extraSchema}
>
  <article class="service-page">
    <div class="container">
      <header class="service-header">
        <div class="service-meta">
          <span class="service-icon" aria-hidden="true">{service.data.icon}</span>
          <span class="tag">{service.data.category}</span>
        </div>
        <h1>{service.data.title}</h1>
        <p class="service-description">{service.data.description}</p>
        <a href="/en/contact/" class="btn-primary">Schedule a call →</a>
      </header>

      <div class="service-body">
        <div class="prose">
          <Content />
        </div>
      </div>

      {faqs.length > 0 && (
        <section class="service-faq">
          <h2>Frequently asked questions</h2>
          <div class="faq-list">
            {faqs.map((f) => (
              <details class="faq-item">
                <summary>{f.question}</summary>
                <p>{f.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      {relatedCases.length > 0 && (
        <aside class="related-cases">
          <h2>Relevant cases</h2>
          <div class="cases-grid">
            {relatedCases.map((c) => (
              <CaseCard
                title={c.data.title}
                description={c.data.description}
                slug={c.id}
                client={c.data.client}
                service={c.data.service}
                result={c.data.result}
                basePath="/en/cases"
              />
            ))}
          </div>
        </aside>
      )}
    </div>

    <CTA
      headline={`Ready to get started with ${service.data.title}?`}
      body={`Schedule a no-obligation introductory call. We'll discuss your situation and honestly tell you what ${service.data.title} can mean for you.`}
      cta={{ label: 'Schedule a call', href: '/en/contact/' }}
    />
  </article>
</Post>

<style>
  .service-page {
    padding-top: 2rem;
  }

  .service-header {
    padding: 3rem 0;
    border-bottom: 1px solid oklch(0.15 0 0);
    margin-bottom: 3rem;
    max-width: 760px;
  }

  .service-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .service-icon {
    font-size: 1.5rem;
    color: oklch(0.65 0.2 250);
  }

  .service-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1rem;
  }

  .service-description {
    font-size: 1.125rem;
    color: oklch(0.68 0 0);
    line-height: 1.7;
    margin-bottom: 1.75rem;
    max-width: 620px;
  }

  .service-body {
    padding-bottom: 4rem;
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .service-faq {
    padding: 4rem 0;
    border-bottom: 1px solid oklch(0.15 0 0);
    max-width: 760px;
  }

  .service-faq h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid oklch(0.18 0 0);
  }

  .faq-item:last-child {
    border-bottom: 1px solid oklch(0.18 0 0);
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    padding: 1.25rem 2rem 1.25rem 0;
    font-size: 1.0625rem;
    font-weight: 500;
    color: oklch(0.95 0 0);
    position: relative;
    transition: color 0.2s ease;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    font-weight: 300;
    color: oklch(0.6 0 0);
    transition: transform 0.2s ease;
  }

  .faq-item[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }

  .faq-item summary:hover {
    color: oklch(0.65 0.2 250);
  }

  .faq-item p {
    margin: 0;
    padding: 0 0 1.5rem;
    color: oklch(0.68 0 0);
    line-height: 1.7;
    font-size: 0.9688rem;
  }

  .related-cases {
    padding: 4rem 0;
  }

  .related-cases h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 1.5rem;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
