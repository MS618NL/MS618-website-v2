    border-radius: 18px;
    overflow: hidden;
    border: 1px solid oklch(0.17 0 0);
  }

  .fib-feature img {
    display: block;
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
  }

  .fib-feature figcaption {
    padding: 1rem 1.25rem;
    font-size: 0.9rem;
    color: oklch(0.66 0 0);
    background: oklch(0.1 0 0);
