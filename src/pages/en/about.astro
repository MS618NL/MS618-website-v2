---
import Page from '@/layouts/Page.astro';
import CTA from '@/components/CTA.astro';
import site from '@/data/site.json';
import { buildTeamPieces } from '@/utils/schema';

const breadcrumbs = [
  { name: 'Home', item: site.url + '/en/' },
  { name: 'About us' },
];
---

<Page
  title="About MS618"
  seoTitle="About MS618 — Clarity when everything moves fast"
  description="MS618 is a tight team of senior specialists. No juniors, no padding — just people who have spent a decade mastering their craft and know where it's heading."
  breadcrumbs={breadcrumbs}
  extraSchema={buildTeamPieces()}
>
  <article class="about-page">
    <div class="container">

      <!-- Hero -->
      <header class="page-header">
        <h1>Clarity when everything moves fast.</h1>
        <p class="lead">MS618 is a tight team of senior specialists. No juniors, no padding — just people who have spent a decade mastering their craft and know where it's heading.</p>
      </header>

      <!-- Story -->
      <section class="about-section story-section">
        <div class="about-grid">
          <div class="story-col">
            <div class="section-label-inline">Why MS618 exists</div>
            <p>MS618 started out of frustration. With agencies that sell big and deliver with juniors. With reports stuffed full of metrics that don't move the needle. With an industry that feeds on complexity instead of results.</p>
            <p>We do it differently. A strategic partner, not a vendor. One that challenges your thinking at board level and is straight with you about what works and what doesn't.</p>
            <p>When AI makes everything possible, the real skill is knowing what to ignore. We give you that clarity. Not by doing more — by choosing better.</p>
          </div>
          <div class="name-col">
            <div class="section-label-inline">The name</div>
            <a href="/en/fibonacci/" class="name-number" aria-label=".618, read the story behind the golden ratio">.618</a>
            <p>MS618 comes from .618 — the golden ratio. A mathematical principle, discovered by Fibonacci, that appears throughout nature: the perfect balance between more and less. It's how we think about marketing. Not everything, but exactly the right things.</p>
            <p class="name-link"><a href="/en/fibonacci/">The story behind the golden ratio →</a></p>
          </div>
        </div>
      </section>

      <!-- Why us -->
      <section class="about-section">
        <div class="section-label-inline">Why us</div>
        <h2 class="section-h2">Proven, not promised.</h2>
        <div class="values-grid">
          <div class="value-item">
            <span class="value-icon">01</span>
            <div>
              <h3>Proven, not promised</h3>
              <p>Every project is done by specialists with more than 10 years of experience. No training programmes on your budget.</p>
            </div>
          </div>
          <div class="value-item">
            <span class="value-icon">02</span>
            <div>
              <h3>Strategy as foundation</h3>
              <p>Every campaign, every piece of content, every euro flows from a clear strategy. No loose actions, no FOMO-driven experiments.</p>
            </div>
          </div>
          <div class="value-item">
            <span class="value-icon">03</span>
            <div>
              <h3>Radical honesty</h3>
              <p>If something doesn't work, we say so. We report on business impact, not vanity metrics.</p>
            </div>
          </div>
          <div class="value-item">
            <span class="value-icon">04</span>
            <div>
              <h3>Built for the long term</h3>
              <p>We build structural growth, not quick hypes. What we set up will still be standing in five years.</p>
            </div>
          </div>
          <div class="value-item value-award">
            <a class="award-badge" href="/en/blog/google-ads-impact-awards-2026/" target="_blank" rel="noopener">
              <img src="/images/google-logo.svg" alt="Google" class="award-logo" width="52" height="18" />
              <div class="award-badge-text">
                <strong>Google Ads Impact Awards 2026</strong>
                <span>Nominated for AI innovation in advertising</span>
              </div>
            </a>
          </div>
        </div>
      </section>

      <!-- Team -->
      <section class="about-section team-section">
        <div class="section-label-inline">The team</div>
        <h2 class="section-h2">Five specialists. No juniors. No noise.</h2>
        <p class="team-intro">We get involved when marketing becomes fragmented, tooling takes over, or visibility no longer generates growth. Experience counts when acceleration demands it.</p>
        <div class="team-grid">

          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jorrit Miedema</h3>
              <span class="member-role">Strategy, SEO & AI</span>
              <span class="member-edu">BSc, Information Technology</span>
              <p>12+ years of growth experience. Former full-service agency owner. AI-first since before ChatGPT. Combines systems thinking with rapid execution.</p>
              <a href="https://linkedin.com/in/jorrit-miedema" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jurjan Groothuis</h3>
              <span class="member-role">Ads specialist</span>
              <span class="member-edu">MSc, International Management</span>
              <p>12+ years in performance advertising and growth strategy. Worked at Google HQ Dublin and led marketing and sales growth for multiple startups and scale-ups.</p>
              <a href="https://linkedin.com/in/jurjan-groothuis" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

          <div class="team-member">
            <div class="member-avatar">P</div>
            <div class="member-info">
              <h3>Peter Ydel</h3>
              <span class="member-role">Lead designer</span>
              <span class="member-edu">BSc, UX & Design</span>
              <p>More than 15 years in brand identity and design, with identity work for names such as Doppio Espresso, Barista Café and CHCO. Also the founder of design studio Ydel Design. Translates strategy into design that builds trust.</p>
              <a href="https://linkedin.com/in/peter-ydel" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

          <div class="team-member">
            <div class="member-avatar">R</div>
            <div class="member-info">
              <h3>Ramin Schultz</h3>
              <span class="member-role">Growth hacker (Los Angeles)</span>
              <span class="member-edu">BSc, Information Management</span>
              <p>Silicon Valley experience. Worked for Nike, Uber and various startups and scale-ups. Brings international perspective and growth methodology.</p>
              <a href="https://linkedin.com/in/ramin-schultz" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

          <div class="team-member">
            <div class="member-avatar">W</div>
            <div class="member-info">
              <h3>Wouter van Haaften</h3>
              <span class="member-role">AI strategy</span>
              <span class="member-edu">MSc, Information Management</span>
              <p>Translates complex AI technology into clear, actionable solutions. The bridge between technology and strategy.</p>
              <a href="https://linkedin.com/in/wouter-van-haaften" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

        </div>
      </section>

      <!-- Location -->
      <section class="about-section location-section">
        <div class="location-grid">
          <div class="location-content">
            <div class="section-label-inline">Location</div>
            <h2 class="section-h2">The office of the future is in Joure</h2>
            <p>MS618 is based at FJ08 — the eighth factory building of Douwe Egberts, on the waterfront in Joure. Restored with oak, walnut and raw steel. A place where people work, cook, make music and build things together. When AI handles the routine, this is what's left: thinking, making, collaborating. Not a corporate office. Something better.</p>
          </div>
          <div class="location-image">
            <img src="/images/pand.jpg" alt="MS618 office FJ08 in Joure" width="1276" height="865" loading="lazy" />
          </div>
        </div>
      </section>

    </div>

    <CTA
      headline="Ready for direction?"
      body="Schedule a strategic intake. 45 minutes, no obligations. Just clarity on where you stand and where you can go."
    />
  </article>
</Page>

<style>
  .about-page {
    padding-top: 1.5rem;
  }

  .page-header {
    padding: 3rem 0 4rem;
    max-width: 760px;
    border-bottom: 1px solid oklch(0.15 0 0);
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }

  .lead {
    font-size: 1.125rem;
    color: oklch(0.68 0 0);
    line-height: 1.75;
  }

  .about-section {
    padding: 4rem 0;
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .section-label-inline {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: oklch(0.63 0 0);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-label-inline::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 1px;
    background: oklch(0.3 0 0);
  }

  .section-h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 2rem;
  }

  /* Story */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .story-col p,
  .name-col p {
    color: oklch(0.65 0 0);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .name-number {
    display: inline-block;
    font-size: 4rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
    margin-bottom: 1.25rem !important;
    font-family: Georgia, serif;
    text-decoration: none;
    /* champagne-gold metallic sheen with a moving highlight, a nod to the golden ratio */
    background: linear-gradient(
      100deg,
      oklch(0.60 0.03 85) 0%,
      oklch(0.72 0.05 88) 25%,
      oklch(0.98 0.05 96) 50%,
      oklch(0.72 0.05 88) 75%,
      oklch(0.60 0.03 85) 100%
    );
    background-size: 200% auto;
    background-position: 0 center;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(0 2px 14px oklch(0.85 0.08 90 / 0.12));
    animation: name-sheen 6.5s linear infinite;
    transition: filter 0.3s ease;
  }

  .name-number:hover {
    filter: drop-shadow(0 2px 22px oklch(0.9 0.1 92 / 0.3));
  }

  @keyframes name-sheen {
    to { background-position: -200% center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .name-number {
      animation: none;
      background: none;
      -webkit-text-fill-color: oklch(0.72 0.04 88);
      color: oklch(0.72 0.04 88);
    }
  }

  .name-link {
    margin-top: -0.25rem;
  }

  .name-link a {
    color: oklch(0.65 0.2 250);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .name-link a:hover {
    opacity: 0.75;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 0.5rem;
  }

  .value-item {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid oklch(0.16 0 0);
    background: oklch(0.11 0 0);
  }

  .value-icon {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: oklch(0.62 0 0);
    padding-top: 0.15rem;
    width: 1.5rem;
  }

  .value-item h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 0.4rem;
  }

  .value-item p {
    font-size: 0.875rem;
    color: oklch(0.65 0 0);
    line-height: 1.6;
  }

  .value-award {
    grid-column: 1 / -1;
    align-items: center;
    border-color: oklch(0.62 0 0);
    background: oklch(0.12 0 0);
  }

  .award-badge {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .award-badge:hover .award-badge-text strong {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .award-logo {
    height: 18px;
    width: auto;
    opacity: 0.9;
    flex-shrink: 0;
  }

  .award-badge-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .award-badge-text strong {
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.88 0 0);
  }

  .award-badge-text span {
    font-size: 0.8125rem;
    color: oklch(0.65 0 0);
  }

  /* Team */
  .team-intro {
    color: oklch(0.65 0 0);
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    font-size: 0.9375rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .team-member {
    border: 1px solid oklch(0.18 0 0);
    padding: 1.75rem;
    background: oklch(0.11 0 0);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .team-member:hover {
    border-color: oklch(0.62 0 0);
    box-shadow: 0 0 20px oklch(0.12 0 0);
  }

  .member-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: oklch(0.15 0 0);
    border: 1px solid oklch(0.28 0 0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: oklch(0.75 0 0);
    letter-spacing: 0;
  }

  .member-info h3 {
    font-size: 1rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 0.2rem;
  }

  .member-role {
    display: block;
    font-size: 0.8125rem;
    color: oklch(0.65 0 0);
    margin-bottom: 0.15rem;
  }

  .member-edu {
    display: block;
    font-size: 0.75rem;
    color: oklch(0.63 0 0);
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }

  .member-info p {
    font-size: 0.875rem;
    color: oklch(0.65 0 0);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .member-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    color: oklch(0.5 0.15 200);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .member-linkedin:hover {
    color: oklch(0.65 0.18 200);
  }

  /* Location */
  .location-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: center;
  }

  .location-content p {
    color: oklch(0.65 0 0);
    line-height: 1.75;
  }

  .location-image {
    width: 100%;
  }

  .location-image img {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: brightness(0.95);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .location-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
