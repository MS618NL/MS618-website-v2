---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CTA from '@/components/CTA.astro';
import site from '@/data/site.json';

const breadcrumbs = [
  { name: 'Home', item: site.url + '/en/' },
  { name: 'About us' },
];
---

<Base
  title="About MS618"
  seoTitle="About MS618 — Direction in acceleration"
  description="MS618 is a compact agency of senior specialists. No juniors, no noise — only people who have mastered their craft and understand its future."
>
  <Header />
  <main id="main-content">
    <div class="container breadcrumb-bar">
      <nav class="breadcrumbs" aria-label="Breadcrumbs">
        <ol>
          <li><a href="/en/">Home</a><span class="sep" aria-hidden="true">/</span></li>
          <li><span aria-current="page">About us</span></li>
        </ol>
      </nav>
    </div>

    <article class="about-page">
      <div class="container">

        <header class="page-header">
          <h1>Providing direction in a world that accelerates.</h1>
          <p class="lead">MS618 is a compact agency of senior specialists. No juniors, no noise — only people who have mastered their craft and understand its future.</p>
        </header>

        <!-- Story -->
        <section class="about-section story-section">
          <div class="about-grid">
            <div class="story-col">
              <div class="section-label-inline">Why MS618 exists</div>
              <p>MS618 was born out of frustration. About agencies that make big promises with junior teams. About reports full of metrics that don't matter. About an industry that grows on noise instead of results.</p>
              <p>We believe there is a better way. An agency that operates as a strategic partner, not a supplier. That thinks along at board level. That honestly says what works and what doesn't.</p>
              <p>In an age where AI makes everything possible, it's easy to get lost in tools, channels and trends. We provide direction. Not by doing more, but by choosing better.</p>
            </div>
            <div class="name-col">
              <div class="section-label-inline">The name</div>
              <p class="name-number">.618</p>
              <p>MS618 comes from .618 — the golden number. The ratio that keeps recurring in nature, architecture and mathematics as the balance between complexity and simplicity. Fibonacci, the golden ratio. It's how we think about marketing: not more, not less, but exactly in proportion.</p>
            </div>
          </div>
        </section>

        <!-- Why us -->
        <section class="about-section">
          <div class="section-label-inline">Why us</div>
          <h2 class="section-h2">Proven, not promised.</h2>
          <div class="values-grid">
            <div class="value-item">
              <span class="value-icon">01</span>
              <div>
                <h3>Proven, not promised</h3>
                <p>Every project is done by specialists with more than 10 years of experience. No training programmes on your budget.</p>
              </div>
            </div>
            <div class="value-item">
              <span class="value-icon">02</span>
              <div>
                <h3>Strategy as foundation</h3>
                <p>Every campaign, every piece of content, every euro flows from a clear strategy. No loose actions, no FOMO-driven experiments.</p>
              </div>
            </div>
            <div class="value-item">
              <span class="value-icon">03</span>
              <div>
                <h3>Radical honesty</h3>
                <p>If something doesn't work, we say so. We report on business impact, not vanity metrics.</p>
              </div>
            </div>
            <div class="value-item">
              <span class="value-icon">04</span>
              <div>
                <h3>Built for the long term</h3>
                <p>We build structural growth, not quick hypes. What we set up will still be standing in five years.</p>
              </div>
            </div>
            <div class="value-item value-award">
              <div class="award-badge">
                <img src="/images/google-logo.svg" alt="Google" class="award-logo" width="52" height="18" />
                <div class="award-badge-text">
                  <strong>Google AI Innovation Award 2025</strong>
                  <span>Recognised as most innovative AI Ads partner</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Team -->
        <section class="about-section team-section">
          <div class="section-label-inline">The team</div>
          <h2 class="section-h2">Five specialists. No juniors. No noise.</h2>
          <p class="team-intro">We get involved when marketing becomes fragmented, tooling takes over, or visibility no longer generates growth. Experience counts when acceleration demands it.</p>
          <div class="team-grid">

            <div class="team-member">
              <div class="member-avatar">J</div>
              <div class="member-info">
                <h3>Jorrit Miedema</h3>
                <span class="member-role">Strategy, SEO & AI</span>
                <span class="member-edu">BSc, Information Technology</span>
                <p>12+ years of growth experience. Former full-service agency owner. AI-first since before ChatGPT.</p>
                <a href="https://linkedin.com/in/jorrit-miedema" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
              </div>
            </div>

            <div class="team-member">
              <div class="member-avatar">J</div>
              <div class="member-info">
                <h3>Jurjan Groothuis</h3>
                <span class="member-role">Ads specialist</span>
                <span class="member-edu">MSc, International Management</span>
                <p>12+ years in performance advertising and growth strategy. Worked at Google HQ Dublin.</p>
                <a href="https://linkedin.com/in/jurjan-groothuis" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
              </div>
            </div>

            <div class="team-member">
              <div class="member-avatar">P</div>
              <div class="member-info">
                <h3>Peter Ydel</h3>
                <span class="member-role">Lead designer</span>
                <span class="member-edu">BSc, UX & Design</span>
                <p>Developed campaigns and visual concepts for international brands.</p>
                <a href="https://linkedin.com/in/peter-ydel" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
              </div>
            </div>

            <div class="team-member">
              <div class="member-avatar">R</div>
              <div class="member-info">
                <h3>Ramin Schultz</h3>
                <span class="member-role">Growth hacker (Los Angeles)</span>
                <span class="member-edu">BSc, Information Management</span>
                <p>Silicon Valley experience. Worked for Nike, Uber and various startups and scale-ups.</p>
                <a href="https://linkedin.com/in/ramin-schultz" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
              </div>
            </div>

            <div class="team-member">
              <div class="member-avatar">W</div>
              <div class="member-info">
                <h3>Wouter van Haaften</h3>
                <span class="member-role">AI strategy</span>
                <span class="member-edu">MSc, Information Management</span>
                <p>Translates complex AI technology into clear, actionable solutions.</p>
                <a href="https://linkedin.com/in/wouter-van-haaften" class="member-linkedin" target="_blank" rel="noopener noreferrer">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
              </div>
            </div>

          </div>
        </section>

        <!-- Location -->
        <section class="about-section location-section">
          <div class="location-grid">
            <div class="location-text">
              <div class="section-label-inline">Location</div>
              <h2 class="section-h2">Built with focus in Joure.</h2>
              <p>Our office is located at the harbour of Joure — a place where calm and focus come together. No trendy co-working space, but our own building where we can think, build and discuss undisturbed.</p>
              <p class="location-address">MS618 B.V. · Slachtedyk 4a · Joure</p>
            </div>
            <div class="location-image">
              <div class="location-placeholder">
                <span>Photo of premises — coming soon</span>
              </div>
            </div>
          </div>
        </section>

      </div>

      <CTA />
    </article>
  </main>
  <Footer />
</Base>

<style>
  .breadcrumb-bar {
    padding-top: calc(4.5rem + 1rem);
    padding-bottom: 0;
  }

  .breadcrumbs { padding: 0.75rem 0; }

  .breadcrumbs ol {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumbs li {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .breadcrumbs a {
    font-size: 0.8125rem;
    color: oklch(0.45 0 0);
    text-decoration: none;
  }

  .breadcrumbs a:hover { color: oklch(0.65 0 0); }

  .breadcrumbs span[aria-current="page"] {
    font-size: 0.8125rem;
    color: oklch(0.55 0 0);
  }

  .sep {
    font-size: 0.75rem;
    color: oklch(0.3 0 0);
    margin: 0 0.1rem;
  }

  .about-page { padding-top: 1.5rem; }

  .page-header {
    padding: 3rem 0 4rem;
    max-width: 760px;
    border-bottom: 1px solid oklch(0.15 0 0);
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }

  .lead {
    font-size: 1.125rem;
    color: oklch(0.55 0 0);
    line-height: 1.75;
  }

  .about-section {
    padding: 4rem 0;
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .section-label-inline {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: oklch(0.4 0 0);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-label-inline::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 1px;
    background: oklch(0.3 0 0);
  }

  .section-h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 2rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .story-col p, .name-col p {
    color: oklch(0.5 0 0);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .name-number {
    font-size: 4rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: oklch(0.25 0 0);
    line-height: 1;
    margin-bottom: 1.25rem !important;
    font-family: Georgia, serif;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 0.5rem;
  }

  .value-item {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid oklch(0.16 0 0);
    background: oklch(0.11 0 0);
  }

  .value-icon {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: oklch(0.35 0 0);
    padding-top: 0.15rem;
    width: 1.5rem;
  }

  .value-item h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 0.4rem;
  }

  .value-item p {
    font-size: 0.875rem;
    color: oklch(0.5 0 0);
    line-height: 1.6;
  }

  .value-award {
    grid-column: 1 / -1;
    align-items: center;
    border-color: oklch(0.22 0 0);
    background: oklch(0.12 0 0);
  }

  .award-badge {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .award-logo {
    height: 18px;
    width: auto;
    opacity: 0.9;
    flex-shrink: 0;
  }

  .award-badge-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .award-badge-text strong {
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.88 0 0);
  }

  .award-badge-text span {
    font-size: 0.8125rem;
    color: oklch(0.45 0 0);
  }

  .team-intro {
    color: oklch(0.5 0 0);
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    font-size: 0.9375rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .team-member {
    border: 1px solid oklch(0.18 0 0);
    padding: 1.75rem;
    background: oklch(0.11 0 0);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .team-member:hover {
    border-color: oklch(0.3 0 0);
    box-shadow: 0 0 20px oklch(0.12 0 0);
  }

  .member-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: oklch(0.15 0 0);
    border: 1px solid oklch(0.28 0 0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: oklch(0.75 0 0);
    letter-spacing: 0;
  }

  .member-info h3 {
    font-size: 1rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 0.2rem;
  }

  .member-role {
    display: block;
    font-size: 0.8125rem;
    color: oklch(0.5 0 0);
    margin-bottom: 0.15rem;
  }

  .member-edu {
    display: block;
    font-size: 0.75rem;
    color: oklch(0.38 0 0);
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }

  .member-info p {
    font-size: 0.875rem;
    color: oklch(0.45 0 0);
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .member-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    color: oklch(0.5 0.15 200);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .member-linkedin:hover {
    color: oklch(0.65 0.18 200);
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .location-text p {
    color: oklch(0.5 0 0);
    line-height: 1.75;
  }

  .location-address {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: oklch(0.38 0 0) !important;
    letter-spacing: 0.03em;
  }

  .location-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    border: 1px solid oklch(0.18 0 0);
    background: oklch(0.11 0 0);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .location-placeholder span {
    font-size: 0.8125rem;
    color: oklch(0.3 0 0);
    letter-spacing: 0.04em;
  }

  @media (max-width: 1024px) {
    .about-grid, .location-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .values-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .team-grid { grid-template-columns: 1fr; }
  }
</style>
