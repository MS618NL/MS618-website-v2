---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CTA from '@/components/CTA.astro';
import LogoSlider from '@/components/LogoSlider.astro';
import site from '@/data/site.json';
import {
  buildOrganizationPiece,
  buildWebsitePiece,
  buildWebpagePiece,
  buildBreadcrumbPiece,
} from '@/utils/schema';

const pageUrl = site.url + '/en/';
const breadcrumbs = [{ name: 'Home' }];

const schemaGraph = [
  buildOrganizationPiece(),
  buildWebsitePiece(),
  buildWebpagePiece(pageUrl, 'MS618 — Direction in acceleration', 'MS618 is a digital agency helping businesses grow with strategic SEO, content marketing and digital performance — without noise, with focus.', breadcrumbs),
  buildBreadcrumbPiece(pageUrl, breadcrumbs),
];
---

<Base
  title="Direction in acceleration"
  seoTitle="MS618 — Direction in acceleration"
  description="MS618 is a digital agency helping businesses grow with strategic SEO, content marketing and digital performance — without noise, with focus."
  ogType="website"
  schemaGraph={schemaGraph}
>
  <Header />
  <main id="main-content">

    <!-- Hero -->
    <section class="hero" aria-label="Hero">
      <div class="hero-overlay"></div>
      <div class="container hero-content">
        <div class="hero-label">
          <span class="label-dot"></span>
          Direction in acceleration
        </div>

        <h1 class="hero-headline">AI makes marketing infinite,<br>and therefore meaningless.</h1>

        <p class="hero-sub">While everyone produces more, brands lose their direction. MS618 brings focus: the right choices, the right channels, the right message.</p>

        <div class="hero-actions">
          <a href="/en/contact/" class="btn-primary">Schedule a call →</a>
          <a href="/en/services/" class="btn-secondary">See our approach</a>
        </div>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">10+</span>
            <span class="stat-label">Years experience</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">50+</span>
            <span class="stat-label">Clients served</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">100%</span>
            <span class="stat-label">Senior specialists</span>
          </div>
        </div>
      </div>

      <div class="hero-scroll" aria-hidden="true">
        <span>Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- Google Award Badge -->
    <div class="award-bar">
      <div class="container">
        <div class="award-inner">
          <img src="/images/google-logo.svg" alt="Google" class="award-google-logo" width="60" height="20" />
          <span class="award-divider"></span>
          <span class="award-text">Google AI Innovation Award 2025</span>
          <span class="award-dot">·</span>
          <span class="award-sub">Recognised as most innovative AI Ads partner</span>
        </div>
      </div>
    </div>

    <!-- Problem -->
    <section class="section problem-section">
      <div class="container">
        <div class="section-label">The problem</div>
        <div class="problem-grid">
          <div class="problem-col">
            <h2>You know you need to do something.<br>But what?</h2>
            <p>AI is everywhere. Your competitor is already using it to build websites, run ads, produce content. Meanwhile you're wondering: do I need a new website? What can I actually do with ChatGPT? And why isn't my marketing bringing in clients anymore?</p>
            <p>The problem isn't that you're doing too little. The problem is that nobody tells you what you should do — and what you can safely ignore.</p>
            <p class="problem-manifesto">You're looking for clients. Not more tools.<br>You're looking for growth. Not more channels.<br>You're looking for someone who handles it. Not someone who sends a report.<br><br>That's exactly what we do.</p>
          </div>
          <div class="problem-col problem-col-right">
            <div class="problem-stat">
              <div class="pstat-number">9 in 10</div>
              <div class="pstat-text">SME owners know they need to do something with AI and online. But not what.</div>
            </div>
            <div class="problem-stat">
              <div class="pstat-number">0 FTE</div>
              <div class="pstat-text">That's how many marketers you need. We combine strategy with AI so you don't have to build a team.</div>
            </div>
            <div class="problem-stat">
              <div class="pstat-number">1 partner</div>
              <div class="pstat-text">Who understands AI, knows your market, and just handles it. That's all you need.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Tools -->
    <div class="ai-tools-bar">
      <div class="container">
        <p class="ai-tools-label">The AI technology behind our approach</p>
        <div class="ai-tools-grid">
          <span class="ai-tool">ChatGPT</span>
          <span class="ai-tool">Claude</span>
          <span class="ai-tool">Gemini</span>
          <span class="ai-tool">Grok</span>
          <span class="ai-tool">Llama</span>
          <span class="ai-tool">Mistral</span>
          <span class="ai-tool">Perplexity</span>
          <span class="ai-tool">Midjourney</span>
          <span class="ai-tool">DeepSeek</span>
          <span class="ai-tool">Clawdbot</span>
          <span class="ai-tool">Antigravity</span>
        </div>
      </div>
    </div>

    <!-- Raptor -->
    <section class="raptor-section">
      <div class="raptor-image-wrap">
        <img
          src="/images/raptor3evolution.jpg"
          alt="SpaceX Raptor engine evolution — three generations, fewer parts each time"
          loading="lazy"
        />
        <div class="raptor-overlay"></div>
      </div>
      <div class="container raptor-content">
        <blockquote class="raptor-quote">
          <div class="raptor-quote-mark">"</div>
          <p>"The best part is no part. The best process is no process."</p>
          <footer>— Elon Musk on the Raptor engine</footer>
        </blockquote>
        <p class="raptor-context">
          Three generations of Raptor. Each iteration: fewer parts, more power. That is also our approach: simplification through iteration.
        </p>
      </div>
    </section>

    <!-- How we work -->
    <section class="section how-section">
      <div class="container">
        <div class="section-label">How we work</div>
        <h2 class="section-title">One system. No noise.</h2>
        <div class="how-grid">
          <div class="how-card">
            <div class="how-number">01</div>
            <h3>Direction</h3>
            <p>We determine where visibility has value — and where you should stop wasting energy.</p>
          </div>
          <div class="how-card">
            <div class="how-number">02</div>
            <h3>Execution</h3>
            <p>From SEO to AI visibility: we build what works and strip what doesn't. No bloat, no padding.</p>
          </div>
          <div class="how-card">
            <div class="how-number">03</div>
            <h3>Growth</h3>
            <p>One scalable system — without needing an entire marketing department.</p>
          </div>
        </div>
        <div class="how-cta">
          <a href="/en/services/" class="btn-secondary">See our approach →</a>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="section team-section" id="team">
      <div class="container">
        <div class="section-label">The team</div>
        <h2 class="section-title">Senior specialists only</h2>
        <p class="section-sub">No juniors, no interns, no bulk. Every project is executed by specialists with at least 8 years of relevant experience.</p>
        <div class="team-grid">
          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jorrit Miedema</h3>
              <span class="member-role">Strategy, SEO & AI</span>
              <span class="member-edu">BSc, Information Technology</span>
              <p>12+ years of growth experience. Former full-service agency owner. AI-first since before ChatGPT.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jurjan Groothuis</h3>
              <span class="member-role">Ads specialist</span>
              <span class="member-edu">MSc, International Management</span>
              <p>12+ years in performance advertising. Worked at Google HQ Dublin.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">P</div>
            <div class="member-info">
              <h3>Peter Ydel</h3>
              <span class="member-role">Lead designer</span>
              <span class="member-edu">BSc, UX & Design</span>
              <p>Developed campaigns and visual concepts for international brands.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">R</div>
            <div class="member-info">
              <h3>Ramin Schultz</h3>
              <span class="member-role">Growth hacker (Los Angeles)</span>
              <span class="member-edu">BSc, Information Management</span>
              <p>Silicon Valley experience. Worked for Nike, Uber and various startups and scale-ups.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">W</div>
            <div class="member-info">
              <h3>Wouter van Haaften</h3>
              <span class="member-role">AI strategy</span>
              <span class="member-edu">MSc, Information Management</span>
              <p>Translates complex AI technology into clear, actionable solutions.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Logo Slider -->
    <LogoSlider
      label="Trusted by leading B2B companies"
      cta={{ label: 'View all clients →', href: '/en/cases/' }}
    />

    <!-- Testimonials -->
    <section class="section testimonials-section">
      <div class="container">
        <div class="section-label">What clients say</div>
        <div class="testimonials-grid">
          <blockquote class="testimonial">
            <p>"MS618 brought structure to our sprawling marketing initiatives. Within 6 months we tripled our organic traffic — and more importantly: we finally understood why it worked."</p>
            <footer>
              <strong>Thomas W.</strong>
              <span>CMO, SaaS Scale-up</span>
            </footer>
          </blockquote>
          <blockquote class="testimonial">
            <p>"We're a niche company in technical solutions. MS618 understood our market immediately and positioned us as the authority in our segment. LinkedIn leads increased 180% in the first year."</p>
            <footer>
              <strong>Anke M.</strong>
              <span>Director, Technical advisory firm</span>
            </footer>
          </blockquote>
          <blockquote class="testimonial">
            <p>"No bullshit, no vague reports. MS618 links every action to a measurable result. That is exactly what we as a data-driven organisation need."</p>
            <footer>
              <strong>Peter L.</strong>
              <span>CEO, E-commerce Scale-up</span>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTA />

  </main>
  <Footer />
</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: transparent;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 40%, transparent 0%, oklch(0.07 0 0) 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 7rem;
    padding-bottom: 5rem;
    max-width: 900px;
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: oklch(0.5 0 0);
    margin-bottom: 2rem;
  }

  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: oklch(0.65 0.2 250);
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-headline {
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1.75rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: oklch(0.55 0 0);
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: oklch(0.98 0 0);
  }

  .stat-label {
    font-size: 0.75rem;
    color: oklch(0.45 0 0);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background: oklch(0.2 0 0);
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: oklch(0.35 0 0);
  }

  .scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, oklch(0.35 0 0), transparent);
    animation: scroll-fade 1.5s ease infinite;
  }

  @keyframes scroll-fade {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  /* Award bar */
  .award-bar {
    border-bottom: 1px solid oklch(0.15 0 0);
    background: oklch(0.11 0 0);
    padding: 0.875rem 0;
  }

  .award-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .award-google-logo {
    height: 18px;
    width: auto;
    opacity: 0.85;
    flex-shrink: 0;
  }

  .award-divider {
    width: 1px;
    height: 1.25rem;
    background: oklch(0.25 0 0);
  }

  .award-text {
    font-size: 0.875rem;
    font-weight: 600;
    color: oklch(0.8 0 0);
    letter-spacing: 0.01em;
  }

  .award-dot {
    color: oklch(0.3 0 0);
  }

  .award-sub {
    font-size: 0.8125rem;
    color: oklch(0.5 0 0);
  }

  /* Sections */
  .section {
    padding: var(--spacing-section, 8rem) 0;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: oklch(0.45 0 0);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 1px;
    background: oklch(0.35 0 0);
  }

  .section-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 0.75rem;
  }

  .section-sub {
    font-size: 1rem;
    color: oklch(0.5 0 0);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  /* Problem */
  .problem-section { border-top: 1px solid oklch(0.15 0 0); }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 2rem;
  }

  .problem-col h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }

  .problem-col p {
    color: oklch(0.5 0 0);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .problem-col-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .problem-stat {
    padding: 1.25rem 1.5rem;
    border: 1px solid oklch(0.18 0 0);
    background: oklch(0.11 0 0);
  }

  .pstat-number {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 0.4rem;
  }

  .pstat-text {
    font-size: 0.875rem;
    color: oklch(0.5 0 0);
    line-height: 1.5;
  }

  .problem-manifesto {
    color: oklch(0.75 0 0) !important;
    font-size: 1rem !important;
    line-height: 1.9 !important;
    border-left: 2px solid oklch(0.22 0 0);
    padding-left: 1.25rem;
    margin-top: 1.5rem;
  }

  /* AI Tools Bar */
  .ai-tools-bar {
    border-top: 1px solid oklch(0.15 0 0);
    border-bottom: 1px solid oklch(0.15 0 0);
    background: oklch(0.1 0 0);
    padding: 2rem 0;
  }

  .ai-tools-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: oklch(0.32 0 0);
    margin-bottom: 1.25rem;
  }

  .ai-tools-grid {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .ai-tool {
    font-size: 1rem;
    font-weight: 600;
    color: oklch(0.42 0 0);
    letter-spacing: 0.02em;
    white-space: nowrap;
    border: 1px solid oklch(0.18 0 0);
    padding: 0.5rem 1rem;
    background: oklch(0.11 0 0);
  }

  .ai-tool:hover {
    color: oklch(0.6 0 0);
    border-color: oklch(0.28 0 0);
  }

  /* Raptor */
  .raptor-section {
    position: relative;
    border-top: 1px solid oklch(0.15 0 0);
  }

  .raptor-image-wrap {
    position: relative;
    width: 100%;
    max-height: 520px;
    overflow: hidden;
  }

  .raptor-image-wrap img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .raptor-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, oklch(0.09 0 0 / 0.2) 0%, oklch(0.09 0 0 / 0.85) 100%);
  }

  .raptor-content {
    padding: 3rem 0 4rem;
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .raptor-quote {
    margin: 0 0 1.5rem;
    padding: 0;
    border: none;
    position: relative;
  }

  .raptor-quote-mark {
    font-family: Georgia, serif;
    font-size: 5rem;
    line-height: 0.6;
    color: oklch(0.25 0 0);
    margin-bottom: 0.5rem;
    display: block;
  }

  .raptor-quote p {
    font-family: Georgia, serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-style: italic;
    color: oklch(0.88 0 0);
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }

  .raptor-quote footer {
    font-size: 0.875rem;
    color: oklch(0.45 0 0);
    letter-spacing: 0.02em;
  }

  .raptor-context {
    font-size: 1rem;
    color: oklch(0.5 0 0);
    max-width: 560px;
    line-height: 1.7;
  }

  /* How */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .how-card {
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: oklch(0.11 0 0);
    padding: 2rem;
    backdrop-filter: blur(4px);
  }

  .how-number {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: oklch(0.35 0 0);
    margin-bottom: 1.25rem;
  }

  .how-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 0.75rem;
  }

  .how-card p {
    font-size: 0.9375rem;
    color: oklch(0.5 0 0);
    line-height: 1.65;
  }

  .how-cta { margin-top: 0.5rem; }

  /* Team */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .team-member {
    border: 1px solid oklch(0.18 0 0);
    padding: 1.75rem;
    background: oklch(0.11 0 0);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .team-member:hover {
    border-color: oklch(0.3 0 0);
    box-shadow: 0 0 20px oklch(0.12 0 0);
  }

  .member-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: oklch(0.15 0 0);
    border: 1px solid oklch(0.28 0 0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: oklch(0.75 0 0);
    letter-spacing: 0;
  }

  .member-info h3 {
    font-size: 1rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 0.2rem;
  }

  .member-role {
    display: block;
    font-size: 0.8125rem;
    color: oklch(0.5 0 0);
    margin-bottom: 0.15rem;
  }

  .member-edu {
    display: block;
    font-size: 0.75rem;
    color: oklch(0.38 0 0);
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }

  .member-info p {
    font-size: 0.875rem;
    color: oklch(0.45 0 0);
    line-height: 1.6;
  }

  /* Testimonials */
  .testimonials-section {
    background: oklch(0.11 0 0);
    border-top: 1px solid oklch(0.15 0 0);
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .testimonial {
    border: 1px solid oklch(0.2 0 0);
    padding: 1.75rem;
    background: oklch(0.09 0 0);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .testimonial:hover {
