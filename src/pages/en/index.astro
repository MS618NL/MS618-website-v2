---
// MS618 Website - English Homepage
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import CTA from '@/components/CTA.astro';
import BlogCard from '@/components/BlogCard.astro';

import { getCollection } from 'astro:content';
import {
  buildOrganizationPiece,
  buildWebsitePiece,
  buildWebpagePiece,
  buildBreadcrumbPiece,
} from '@/utils/schema';
import site from '@/data/site.json';

const recentPosts = (await getCollection('blog'))
  .filter((p) => !p.data.noindex)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const pageUrl = site.url + '/en/';
const breadcrumbs = [{ name: 'Home' }];

const schemaGraph = [
  buildOrganizationPiece(),
  buildWebsitePiece(),
  buildWebpagePiece(pageUrl, 'MS618 — AI Marketing Agency for B2B | Senior Specialists, Real Growth', 'No junior teams, no scattered tactics. MS618 combines senior expertise with AI for measurable B2B growth — SEO, paid ads, content and analytics. One system.', breadcrumbs),
  buildBreadcrumbPiece(pageUrl, breadcrumbs),
];
---

<Base
  title="Direction in acceleration"
  seoTitle="MS618 — AI Marketing Agency for B2B | Senior Specialists, Real Growth"
  description="No junior teams, no scattered tactics. MS618 combines senior expertise with AI for measurable B2B growth — SEO, paid ads, content and analytics. One system."
  ogType="website"
  rss={true}
  schemaGraph={schemaGraph}
>
  <Header />
  <main id="main-content">

    <!-- Hero -->
    <Hero
      badgeText="Direction in acceleration"
      headlinePrefix="AI changes "
      headlineAccent="every day."
      rotatingWords={['marketing', 'your business', 'the world']}
      subheadline="More content, more tools, more channels — and somehow less clarity. We cut through it. The right strategy, the right tools, a system that actually works. No marketing department required."
      cta={{ label: 'Schedule a call', href: '/en/contact/' }}
    />

    <!-- Google Award Badge -->
    <a href="/en/blog/google-ads-impact-awards-2026/" target="_blank" rel="noopener" class="award-bar">
      <div class="container">
        <div class="award-inner">
          <span class="award-google-text">Google</span>
          <span class="award-divider"></span>
          <span class="award-text">Ads Impact Awards 2026</span>
          <span class="award-dot">·</span>
          <span class="award-sub">Nominated for AI innovation in advertising</span>
        </div>
      </div>
    </a>

    <!-- Problem -->
    <section class="problem-section" id="approach">
      <div class="container">
        <div class="section-label">The problem</div>
        <div class="problem-grid">
          <div class="problem-col">
            <h2>You know you need to do something.<br>But what?</h2>
            <p>AI is everywhere. Your competitor is already using it to build websites, run ads, produce content. Meanwhile you're wondering: do I need a new website? What can I actually do with ChatGPT? And why isn't my marketing bringing in clients anymore?</p>
            <p>The problem isn't that you're doing too little. The problem is that nobody tells you what you should do — and what you can safely ignore.</p>
            <p class="problem-manifesto">You're looking for clients. Not more tools.<br>You're looking for growth. Not more channels.<br>You're looking for someone who handles it. Not someone who sends a report.</p>
            <p class="problem-conclusion">That's exactly what we do.</p>
          </div>
          <div class="problem-col problem-col-right">
            <div class="problem-stat">
              <div class="pstat-number">9 in 10</div>
              <div class="pstat-text">SME businesses know they need to do something with AI and online. But not what.</div>
            </div>
            <div class="problem-stat">
              <div class="pstat-number">0 FTE</div>
              <div class="pstat-text">That's how many marketers you need. We combine strategy with AI so you don't have to build a team.</div>
            </div>
            <div class="problem-stat">
              <div class="pstat-number">1 partner</div>
              <div class="pstat-text">Who understands AI, knows your market, and just handles it. That's all you need.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Tools -->
    <div class="ai-tools-bar">
      <div class="container">
        <p class="ai-tools-label">The AI models we deploy for your business</p>
        <p class="ai-tools-subtitle">We select, combine and implement the best AI for your situation. You get the results, we handle the technology.</p>
      </div>
      <div class="ai-tools-static">
        <span class="ai-tool">Gemini</span>
        <span class="ai-tool">Grok</span>
        <span class="ai-tool">Perplexity</span>
        <span class="ai-tool">DeepSeek</span>
        <span class="ai-tool">Midjourney</span>
        <span class="ai-tool">Seedance</span>
        <span class="ai-tool">Nano Banana</span>
        <span class="ai-tool">ChatGPT</span>
        <span class="ai-tool">Antigravity</span>
        <span class="ai-tool ai-tool-claude" data-claude>Claude</span>
        <span class="claude-streak"></span>
      </div>
    </div>

    <script>
      function initStreak(container) {
        const streak = container.querySelector('.claude-streak');
        const claude = container.querySelector('[data-claude]');
        const tools = container.querySelectorAll('.ai-tool');
        if (!streak || !claude) return;

        function moveTo(el) {
          const parentRect = container.getBoundingClientRect();
          const elRect = el.getBoundingClientRect();
          streak.style.left = (elRect.left - parentRect.left + elRect.width / 2) + 'px';
          streak.style.top = (elRect.bottom - parentRect.top + 4) + 'px';
          streak.style.width = (elRect.width * 1) + 'px';
        }

        moveTo(claude);

        tools.forEach(tool => {
          tool.addEventListener('mouseenter', () => moveTo(tool));
        });

        container.addEventListener('mouseleave', () => moveTo(claude));
        window.addEventListener('resize', () => moveTo(claude));
      }

      document.querySelectorAll('.ai-tools-static').forEach(initStreak);
    </script>

    <!-- Raptor -->
    <section class="raptor-section">
      <div class="container">
        <div class="raptor-image-wrap">
          <img
            src="/images/raptor3evolution.jpg"
            alt="SpaceX Raptor engine evolution — three generations, fewer parts each time"
            width="1456"
            height="915"
            loading="lazy"
          />
        </div>
        <div class="raptor-content">
          <blockquote class="raptor-quote">
            <p>"The best part is no part. The best process is no process."</p>
            <footer>— Elon Musk</footer>
          </blockquote>
          <p class="raptor-context">
            Three generations of Raptor. Each iteration: fewer parts, more thrust. We work the same way — strip out what doesn't need to be there, and everything that's left gets sharper.
          </p>
        </div>
      </div>
    </section>

    <!-- How we work -->
    <section class="how-section">
      <div class="container">
        <div class="section-label">How we work</div>
        <h2 class="section-title">One system. No noise.</h2>
        <div class="how-grid">
          <div class="how-card">
            <div class="how-number">01</div>
            <h3>Direction</h3>
            <p>We determine where visibility has value — and where you should stop wasting energy.</p>
          </div>
          <div class="how-card">
            <div class="how-number">02</div>
            <h3>Execution</h3>
            <p>From SEO to AI visibility: we build what works and strip what doesn't. No bloat, no padding.</p>
          </div>
          <div class="how-card">
            <div class="how-number">03</div>
            <h3>Growth</h3>
            <p>One scalable system — without needing an entire marketing department.</p>
          </div>
        </div>
        <div class="how-cta">
          <a href="/en/services/" class="btn-secondary">View our approach →</a>
        </div>
      </div>
    </section>

    <!-- Why MS618 -->
    <section class="why-section">
      <div class="container">
        <div class="section-label">Why MS618</div>
        <h2 class="section-title">International expertise. Local impact.</h2>
        <div class="why-grid">
          <div class="why-content">
            <p>Our team operates on both sides of the Atlantic. In the US we work with startups, scale-ups and PE-backed companies — in Silicon Valley, where the tech reshaping your market is being built right now.</p>
            <p>Back in the Netherlands, we bring that same speed, tooling and thinking to ambitious SMEs. Businesses that want to grow but don't have an in-house marketing team. That know something needs to change — just not where to start.</p>
            <p class="why-tagline">Not a vendor. A partner.</p>
          </div>
          <aside class="why-quote">
            <p>The best technology and strategy in the world shouldn't be reserved for companies with nine-figure budgets.</p>
            <p>When you work with us, you get the same models, the same thinking, the same ambition — just applied to your business.</p>
          </aside>
        </div>
      </div>
    </section>

    <!-- Client Logos -->
    <section class="clients-section">
      <div class="container">
        <div class="section-label">Trusted by</div>
        <div class="clients-grid">
          <div class="client-logo"><img src="/images/clients/inspecto-visio.png" alt="Inspecto Visio" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/ndo-nederland.png" alt="NDO Nederland" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/kis-group.png" alt="KIS Group" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/fugro.png" alt="Fugro" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/christmas-brothers.svg" alt="Christmas Brothers" loading="lazy" /></div>
          <div class="client-logo client-logo--bright"><img src="/images/clients/step2.svg" alt="STEP2" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/swoop.png" alt="Swoop" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/moovs.png" alt="Moovs" loading="lazy" /></div>
          <div class="client-logo client-logo--bright"><img src="/images/clients/bedrijfskleding-online.webp" alt="Bedrijfskleding Online" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/zonklaar.svg" alt="ZONklaar" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/hoekstra-partners.png" alt="Hoekstra & Partners" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/friesland-boating.jpg" alt="Friesland Boating" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/holtara.svg" alt="Holtara" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/houtmethistorie.svg" alt="Hout Met Historie" loading="lazy" /></div>
          <div class="client-logo client-logo--bright"><img src="/images/clients/dvm.svg" alt="DVM" loading="lazy" /></div>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="team-section" id="team">
      <div class="container">
        <div class="section-label">The team</div>
        <h2 class="section-title">Five specialists. No juniors. No noise.</h2>
        <p class="section-sub">We get involved when marketing becomes fragmented, tooling takes over, or visibility no longer generates growth. Experience counts when acceleration demands it.</p>
        <div class="team-grid">
          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jorrit Miedema</h3>
              <span class="member-role">Strategy, SEO & AI</span>
              <span class="member-edu">BSc, Information Technology</span>
              <p>12+ years of growth experience. Former full-service agency owner. AI-first since before ChatGPT.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jurjan Groothuis</h3>
              <span class="member-role">Ads specialist</span>
              <span class="member-edu">MSc, International Management</span>
              <p>12+ years in performance advertising. Worked at Google HQ Dublin.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">P</div>
            <div class="member-info">
              <h3>Peter Ydel</h3>
              <span class="member-role">Lead designer</span>
              <span class="member-edu">BSc, UX & Design</span>
              <p>Developed campaigns and visual concepts for international brands.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">R</div>
            <div class="member-info">
              <h3>Ramin Schultz</h3>
              <span class="member-role">Growth hacker (Los Angeles)</span>
              <span class="member-edu">BSc, Information Management</span>
              <p>Silicon Valley experience. Worked for Nike, Uber and various startups and scale-ups.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">W</div>
            <div class="member-info">
              <h3>Wouter van Haaften</h3>
              <span class="member-role">AI strategy</span>
              <span class="member-edu">MSc, Information Management</span>
              <p>Translates complex AI technology into clear, actionable solutions.</p>
            </div>
          </div>
        </div>
      </div>
    </section>



    <!-- Testimonials -->
    <section class="testimonials-section">
      <div class="container">
        <div class="section-label">What clients say</div>
        <div class="testimonials-grid">
          <blockquote class="testimonial">
            <p>"Jorrit and the MS618 team helped us tremendously with a strong digital marketing strategy, including implementing the latest AI insights. We became visible in ChatGPT and other LLMs very quickly. Jorrit thinks and acts fast, is creative and commercially sharp. Highly recommended for anyone who wants to give their business a boost."</p>
            <footer>
              <strong>Suzanne Legtenberg</strong>
              <span>Marketing Manager, Waimakers / Fugro</span>
            </footer>
          </blockquote>
          <blockquote class="testimonial">
            <p>"We've been working with Jorrit and the MS618 team consistently for over three years. Their SEO expertise has been instrumental in helping Swoop significantly improve our search rankings. They are proactive, responsive, and truly understand our business goals. Highly recommend MS618."</p>
            <footer>
              <strong>Peter Evenson</strong>
              <span>CEO, Swoop</span>
            </footer>
          </blockquote>
          <blockquote class="testimonial">
            <p>"Jorrit is an indispensable sparring partner for me in the rapidly changing world of AI. He connects strategy, innovation and practical applicability. Thanks to that combination, we consistently make concrete progress. Thanks Jorrit!"</p>
            <footer>
              <strong>Olaf Keur</strong>
              <span>CEO, KIS Group</span>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Latest Blog Posts -->
    {recentPosts.length > 0 && (
      <section class="blog-section">
        <div class="container">
          <div class="section-header">
            <div>
              <div class="section-label">Knowledge & insights</div>
              <h2 class="section-title">Latest articles</h2>
            </div>
            <a href="/en/blog/" class="btn-secondary">All articles →</a>
          </div>
          <div class="blog-grid">
            {recentPosts.map((post) => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                slug={post.id}
                publishDate={post.data.publishDate}
                category={post.data.category}
                author={post.data.author}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <CTA />

  </main>
  <Footer />
</Base>

<style>
  /* ── Section labels ── */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 0.75rem;
  }

  .section-label::before {
    content: '';
    width: 1.5rem;
    height: 1px;
    background: #444;
  }

  .section-title {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #fafafa;
  }

  .section-sub {
    font-size: 0.9375rem;
    color: #666;
    max-width: 480px;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  /* ── Award bar ── */
  .award-bar {
    display: block;
    border-bottom: 1px solid #1a1a1a;
    background: #0d0d0d;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
  }

  .award-inner {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .award-google-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #888;
    letter-spacing: -0.01em;
  }

  .award-divider {
    display: block;
    width: 1px;
    height: 1rem;
    background: #333;
  }

  .award-text {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #888;
    letter-spacing: 0.01em;
  }

  .award-dot {
    color: #333;
    font-size: 0.875rem;
  }

  .award-sub {
    font-size: 0.8125rem;
    color: #555;
  }

  /* ── Problem ── */
  .problem-section {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 6rem 0;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 2rem;
  }

  .problem-col h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #fafafa;
    margin-bottom: 1.25rem;
  }

  .problem-col p {
    color: #666;
    line-height: 1.65;
    margin-bottom: 0.875rem;
    font-size: 0.9375rem;
  }

  .problem-col-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .problem-stat {
    padding: 1.25rem 1.5rem;
    background: #0f0f0f;
    border: 1px solid #1a1a1a;
  }

  .pstat-number {
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: #fafafa;
    margin-bottom: 0.375rem;
  }

  .pstat-text {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.5;
  }

  .problem-manifesto {
    color: #888 !important;
    font-size: 0.9375rem !important;
    line-height: 1.7 !important;
    border-left: 2px solid #2a2a2a;
    padding-left: 1rem;
    margin-top: 1.5rem;
  }

  .problem-conclusion {
    color: #fafafa !important;
    font-size: 1rem !important;
    font-weight: 500;
    margin-top: 1.5rem;
  }

  /* ── Why MS618 ── */
  .why-section {
    background: #0d0d0d;
    border-top: 1px solid #1a1a1a;
    padding: 6rem 0;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 2rem;
    align-items: start;
  }

  .why-content p {
    font-size: 0.9375rem;
    color: #666;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .why-tagline {
    color: #fafafa !important;
    font-weight: 500;
    font-size: 1rem !important;
    margin-top: 1.5rem;
  }

  .why-quote {
    border-left: 2px solid #333;
    padding-left: 1.5rem;
  }

  .why-quote p {
    font-size: 0.9375rem;
    color: #777;
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ── Clients ── */
  .clients-section {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 4rem 0;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2.5rem 4rem;
    margin-top: 2rem;
    align-items: center;
  }

  .client-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 32px;
  }

  .client-logo img {
    max-width: 130px;
    max-height: 32px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%) invert(1) brightness(0.7);
    opacity: 0.6;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .client-logo:hover img {
    filter: grayscale(100%) invert(1) brightness(0.9);
    opacity: 0.9;
  }

  .client-logo--bright img {
    filter: grayscale(100%) invert(1) brightness(1);
    opacity: 0.75;
  }

  .client-logo--bright:hover img {
    filter: grayscale(100%) invert(1) brightness(1);
    opacity: 0.95;
  }

  @media (max-width: 1024px) {
    .clients-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem 3rem;
    }
  }

  @media (max-width: 768px) {
    .clients-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem 2rem;
    }

    .client-logo {
      height: 26px;
    }

    .client-logo img {
      max-height: 26px;
      max-width: 110px;
    }
  }

  @media (max-width: 480px) {
    .clients-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  /* ── AI Tools Bar ── */
  .ai-tools-bar {
    border-top: 1px solid #1a1a1a;
    border-bottom: 1px solid #1a1a1a;
    background: #0d0d0d;
    padding: 2.5rem 0 3rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .ai-tools-label {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #666;
    margin-bottom: 0.25rem;
  }

  .ai-tools-subtitle {
    font-size: 0.8125rem;
    color: #555;
    max-width: 480px;
    margin: 0 auto 2rem;
    line-height: 1.5;
  }

  .ai-tools-static {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
  }

  .ai-tool {
    font-size: 1.5rem;
    font-weight: 500;
    color: #555;
    letter-spacing: -0.01em;
    white-space: nowrap;
    cursor: default;
    transition: color 0.3s ease;
  }

  .ai-tool:hover {
    color: #888;
  }

  .ai-tool-claude {
    font-size: 1.75rem;
    font-weight: 700;
    color: #ddd;
  }

  .ai-tool-claude:hover {
    color: #fff;
  }

  .claude-streak {
    position: absolute;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, #a78bfa, #60a5fa, #34d399);
    background-size: 200% 100%;
    animation: gradient-shift-streak 6s ease infinite;
    transition: left 0.4s ease, top 0.4s ease, width 0.4s ease;
    transform: translateX(-50%);
    pointer-events: none;
  }

