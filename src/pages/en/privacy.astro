    background: #080808;
  }

  .legal-content {
    max-width: 720px;
  }

  .legal-content h1 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 0.5rem;
  }

  .legal-updated {
