    color: oklch(0.9 0 0);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 2rem;
    border-top: 1px solid oklch(0.15 0 0);
  }

  .legal-content h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.75 0 0);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .legal-content p {
    font-size: 0.9375rem;
    color: oklch(0.6 0 0);
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .legal-content ul {
    margin: 0.75rem 0 1rem 1.25rem;
    list-style: disc;
  }

  .legal-content ul li {
    font-size: 0.9375rem;
    color: oklch(0.6 0 0);
    line-height: 1.8;
    margin-bottom: 0.25rem;
  }

  .legal-content a {
    color: oklch(0.75 0 0);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal-content a:hover {
    color: oklch(0.95 0 0);
