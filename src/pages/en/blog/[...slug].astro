---
import Post from '@/layouts/Post.astro';
import CTA from '@/components/CTA.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '@/utils/seo';
import site from '@/data/site.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog-en');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const author = site.team.find((m) => m.name === post.data.author) as any;

const allPosts = await getCollection('blog-en');
const relatedPosts = allPosts
  .filter(
    (p) =>
      p.id !== post.id &&
      !p.data.noindex &&
      (post.data.relatedPosts.includes(p.id) || p.data.category === post.data.category)
  )
  .slice(0, 3);

const breadcrumbs = [
  { name: 'Home', item: site.url + '/en/' },
  { name: 'Blog', item: `${site.url}/en/blog/` },
  { name: post.data.title },
];
---

<Post
  title={post.data.title}
  seoTitle={post.data.seoTitle}
  description={post.data.description}
  ogImage={post.data.ogImage}
  noindex={post.data.noindex}
  publishDate={post.data.publishDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  breadcrumbs={breadcrumbs}
>
  <article class="blog-post">
    <div class="container">
      <header class="post-header">
        <div class="post-meta">
          <span class="tag">{post.data.category}</span>
          <time datetime={post.data.publishDate.toISOString()}>
            {formatDate(post.data.publishDate)}
          </time>
          {post.data.updatedDate && post.data.updatedDate.getTime() !== post.data.publishDate.getTime() && (
            <span class="updated">
              Updated {formatDate(post.data.updatedDate)}
            </span>
          )}
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
        <div class="post-author">
          <div class="author-avatar">{post.data.author.split(' ').map((n: string) => n[0]).join('')}</div>
          <span>By {author ? <a href={`/en/about/#${author.slug}`}>{post.data.author}</a> : post.data.author}{author?.jobTitle && `, ${author.jobTitle}`}</span>
        </div>
      </header>

      <div class="post-body">
        <div class="prose">
          <Content />
        </div>
      </div>

      {author?.bio && (
        <aside class="author-bio">
          <div class="author-bio-avatar">{post.data.author.split(' ').map((n: string) => n[0]).join('')}</div>
          <div class="author-bio-text">
            <strong>{post.data.author}</strong>
            <span class="author-bio-role">{author.jobTitle}</span>
            <p>{author.bioEn ?? author.bio}</p>
            {author.linkedin && <a href={author.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn →</a>}
          </div>
        </aside>
      )}

      {relatedPosts.length > 0 && (
        <aside class="related-posts">
          <h2>Related articles</h2>
          <div class="related-grid">
            {relatedPosts.map((p) => (
              <BlogCard
                title={p.data.title}
                description={p.data.description}
                slug={p.id}
                publishDate={p.data.publishDate}
                category={p.data.category}
                author={p.data.author}
                basePath="/en/blog"
              />
            ))}
          </div>
        </aside>
      )}
    </div>

    <CTA
      headline="Need help with your strategy?"
      body="We turn theory into practice. Schedule a no-obligation call with our team."
    />
  </article>
</Post>

<style>
  .blog-post {
    padding-top: 2rem;
    padding-bottom: 0;
  }

  .post-header {
    padding: 3rem 0;
    border-bottom: 1px solid oklch(0.15 0 0);
    margin-bottom: 3rem;
    max-width: 720px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  time, .updated {
    font-size: 0.8125rem;
    color: oklch(0.63 0 0);
  }

  .updated {
    color: oklch(0.63 0 0);
  }

  .post-header h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .post-description {
    font-size: 1.125rem;
    color: oklch(0.68 0 0);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.875rem;
    color: oklch(0.68 0 0);
  }

  .author-avatar {
    width: 2rem;
    height: 2rem;
    border: 1px solid oklch(0.25 0 0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 700;
    color: oklch(0.68 0 0);
  }

  .post-body {
    display: grid;
    grid-template-columns: 1fr;
    padding-bottom: 4rem;
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .post-author span a {
    color: oklch(0.9 0 0);
    text-decoration: none;
    border-bottom: 1px solid oklch(0.3 0 0);
  }

  .post-author span a:hover {
    color: oklch(0.98 0 0);
    border-bottom-color: oklch(0.6 0 0);
  }

  .author-bio {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    max-width: 720px;
    margin: 3rem 0 0;
    padding: 1.5rem;
    border: 1px solid oklch(0.18 0 0);
    border-radius: 14px;
    background: oklch(0.1 0 0);
  }

  .author-bio-avatar {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    border: 1px solid oklch(0.25 0 0);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 700;
    color: oklch(0.85 0 0);
  }

  .author-bio-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .author-bio-text strong {
    color: oklch(0.98 0 0);
    font-size: 0.9375rem;
  }

  .author-bio-role {
    color: oklch(0.62 0 0);
    font-size: 0.8125rem;
  }

  .author-bio-text p {
    margin: 0.5rem 0;
    color: oklch(0.72 0 0);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .author-bio-text > a {
    color: oklch(0.65 0.2 250);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    width: fit-content;
  }

  .author-bio-text > a:hover {
    text-decoration: underline;
  }

  :global(.post-figure) {
    margin: 2.5rem 0;
    border: 1px solid oklch(0.18 0 0);
    background: oklch(0.1 0 0);
    overflow: hidden;
  }

  :global(.post-image) {
    width: 100%;
    height: auto;
    display: block;
  }

  :global(.post-figure figcaption) {
    padding: 0.75rem 1rem;
    font-size: 0.8125rem;
    color: oklch(0.63 0 0);
    border-top: 1px solid oklch(0.15 0 0);
  }

  .related-posts {
    padding: 4rem 0;
  }

  .related-posts h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 1.5rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
