  }

  .legal-content {
    max-width: 720px;
  }

  .legal-content h1 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 0.5rem;
  }

  .legal-updated {
    font-size: 0.8125rem;
    color: oklch(0.63 0 0);
    margin-bottom: 3rem;
  }

  .legal-content h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: oklch(0.9 0 0);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 2rem;
    border-top: 1px solid oklch(0.15 0 0);
  }

  .legal-content p {
    font-size: 0.9375rem;
    color: oklch(0.68 0 0);
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .legal-content a {
    color: oklch(0.75 0 0);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal-content a:hover {
    color: oklch(0.95 0 0);
  }

  .legal-content strong {
    color: oklch(0.8 0 0);
  }

  .legal-contact {
    margin-top: 3rem;
    padding: 1.5rem;
    border: 1px solid oklch(0.15 0 0);
    background: oklch(0.1 0 0);
  }

  .legal-contact p {
    margin-bottom: 0.25rem;
  }
</style>
