---
import Page from '@/layouts/Page.astro';
import CTA from '@/components/CTA.astro';
import { getCollection, render } from 'astro:content';
import { buildLocalBusinessPiece, buildFaqPiece } from '@/utils/schema';
import { canonicalUrl } from '@/utils/seo';
import site from '@/data/site.json';

export async function getStaticPaths() {
  const pages = await getCollection('local');
  return pages.map((entry) => ({
    params: { locatie: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pageUrl = canonicalUrl(`/${entry.id}/`);
const breadcrumbs = [
  { name: 'Home', item: site.url },
  { name: entry.data.title },
];

const faqs = entry.data.faq ?? [];
const extraSchema = [
  buildLocalBusinessPiece(),
  ...(faqs.length > 0 ? [buildFaqPiece(pageUrl, faqs)] : []),
];
---

<Page
  title={entry.data.title}
  seoTitle={entry.data.seoTitle}
  description={entry.data.description}
  ogImage={entry.data.ogImage}
  noindex={entry.data.noindex}
  breadcrumbs={breadcrumbs}
  extraSchema={extraSchema}
  enAlternate={false}
  altPath="/en/"
>
  <article class="local-page">
    <div class="container">
      <header class="local-header">
        <span class="tag">{entry.data.region}</span>
        <h1>{entry.data.title}</h1>
        <p class="local-description">{entry.data.description}</p>
        <a href="/contact/" class="btn-primary">Plan een gesprek →</a>
        <p class="local-trust">
          <span class="trust-item"><span class="trust-star" aria-hidden="true">★</span> 5,0 op Google · 20 reviews</span>
          <span class="trust-sep" aria-hidden="true">·</span>
          <a class="trust-item trust-link" href="/blog/google-ads-impact-awards-2026/">Genomineerd voor de Google Ads Impact Awards 2026</a>
        </p>
      </header>

      <div class="local-body">
        <div class="prose">
          <Content />
        </div>
      </div>

      {faqs.length > 0 && (
        <section class="local-faq">
          <h2>Veelgestelde vragen</h2>
          <div class="faq-list">
            {faqs.map((f) => (
              <details class="faq-item">
                <summary>{f.question}</summary>
                <p>{f.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}
    </div>

    <CTA
      headline={`Marketing in ${entry.data.region} die werkt?`}
      body="Plan een vrijblijvend kennismakingsgesprek. We bespreken eerlijk waar voor jouw bedrijf de meeste groei zit."
    />
  </article>
</Page>

<style>
  .local-page {
    padding-top: 2rem;
  }

  .local-header {
    padding: 3rem 0;
    border-bottom: 1px solid oklch(0.15 0 0);
    margin-bottom: 3rem;
    max-width: 760px;
  }

  .local-header .tag {
    display: inline-block;
    margin-bottom: 1.25rem;
  }

  .local-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: oklch(0.98 0 0);
    margin-bottom: 1rem;
  }

  .local-description {
    font-size: 1.125rem;
    color: oklch(0.68 0 0);
    line-height: 1.7;
    margin-bottom: 1.75rem;
    max-width: 620px;
  }

  .local-trust {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.75rem;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: oklch(0.68 0 0);
  }

  .trust-star {
    color: oklch(0.8 0.09 90);
  }

  .trust-sep {
    color: oklch(0.4 0 0);
  }

  .trust-link {
    color: oklch(0.68 0 0);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .trust-link:hover {
    color: oklch(0.92 0 0);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .local-body {
    padding-bottom: 4rem;
    border-bottom: 1px solid oklch(0.15 0 0);
  }

  .local-faq {
    padding: 4rem 0;
    max-width: 760px;
  }

  .local-faq h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: oklch(0.98 0 0);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid oklch(0.18 0 0);
  }

  .faq-item:last-child {
    border-bottom: 1px solid oklch(0.18 0 0);
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    padding: 1.25rem 2rem 1.25rem 0;
    font-size: 1.0625rem;
    font-weight: 500;
    color: oklch(0.95 0 0);
    position: relative;
    transition: color 0.2s ease;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    font-weight: 300;
    color: oklch(0.6 0 0);
    transition: transform 0.2s ease;
  }

  .faq-item[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }

  .faq-item summary:hover {
    color: oklch(0.65 0.2 250);
  }

  .faq-item p {
    margin: 0;
    padding: 0 0 1.5rem;
    color: oklch(0.68 0 0);
    line-height: 1.7;
    font-size: 0.9688rem;
  }
</style>
