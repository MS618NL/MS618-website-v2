---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import CTA from '@/components/CTA.astro';
import BlogCard from '@/components/BlogCard.astro';

import { getCollection } from 'astro:content';
import {
  buildOrganizationPiece,
  buildWebsitePiece,
  buildWebpagePiece,
  buildBreadcrumbPiece,
} from '@/utils/schema';
import site from '@/data/site.json';

const recentPosts = (await getCollection('blog'))
  .filter((p) => !p.data.noindex)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const pageUrl = site.url + '/';
const breadcrumbs = [{ name: 'Home' }];

const schemaGraph = [
  buildOrganizationPiece(),
  buildWebsitePiece(),
  buildWebpagePiece(pageUrl, 'MS618 — Richting in versnelling', site.description, breadcrumbs),
  buildBreadcrumbPiece(pageUrl, breadcrumbs),
];
---

<Base
  title="Richting in versnelling"
  seoTitle="MS618 — Richting in versnelling"
  description={site.description}
  ogType="website"
  rss={true}
  schemaGraph={schemaGraph}
>
  <Header />
  <main id="main-content">

    <!-- Hero -->
    <Hero />

    <!-- Google Award Badge -->
    <div class="award-bar">
      <div class="container">
        <div class="award-inner">
          <span class="award-google-text">Google</span>
          <span class="award-divider"></span>
          <span class="award-text">Ads Impact Awards 2026</span>
          <span class="award-dot">·</span>
          <span class="award-sub">Genomineerd voor AI-innovatie in advertising</span>
        </div>
      </div>
    </div>

    <!-- Problem -->
    <section class="problem-section" id="aanpak">
      <div class="container">
        <div class="section-label">Het probleem</div>
        <div class="problem-grid">
          <div class="problem-col">
            <h2>Je weet dat je iets moet.<br>Maar wat?</h2>
            <p>AI is overal. Je concurrent maakt er al websites mee, advertenties, content. Ondertussen vraag je je af: moet ik een nieuwe website? Wat kan ik eigenlijk met ChatGPT? En waarom levert mijn marketing geen klanten meer op?</p>
            <p>Het probleem is niet dat je te weinig doet. Het probleem is dat niemand je vertelt wat je wél moet doen — en wat je gerust kunt laten.</p>
            <p class="problem-manifesto">Je zoekt klanten. Niet meer tools.<br>Je zoekt groei. Niet meer kanalen.<br>Je zoekt iemand die het regelt. Niet iemand die een rapport stuurt.</p>
            <p class="problem-conclusion">Dat is precies wat wij doen.</p>
          </div>
          <div class="problem-col problem-col-right">
            <div class="problem-stat">
              <div class="pstat-number">9 van de 10</div>
              <div class="pstat-text">MKB-bedrijven weten dat ze iets moeten met AI en online. Maar niet wat.</div>
            </div>
            <div class="problem-stat">
              <div class="pstat-number">0 FTE</div>
              <div class="pstat-text">Zoveel marketingmensen heb je nodig. Wij combineren strategie met AI zodat jij geen team hoeft te bouwen.</div>
            </div>
            <div class="problem-stat">
              <div class="pstat-number">1 partner</div>
              <div class="pstat-text">Die AI begrijpt, jouw markt kent, en het gewoon regelt. Meer heb je niet nodig.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Tools -->
    <div class="ai-tools-bar">
      <div class="container">
        <p class="ai-tools-label">De AI-modellen die wij inzetten voor jouw bedrijf</p>
        <p class="ai-tools-subtitle">Wij selecteren, combineren en implementeren de beste AI voor jouw situatie. Jij krijgt het resultaat, wij regelen de techniek.</p>
      </div>
      <div class="ai-tools-marquee">
        <div class="ai-tools-track">
          <span class="ai-tool">ChatGPT</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Claude</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Gemini</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Grok</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Perplexity</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">DeepSeek</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Midjourney</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Nano Banana</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Seedance</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Antigravity</span>
          <span class="ai-tool-dot"></span>
          <!-- Duplicate for seamless loop -->
          <span class="ai-tool">ChatGPT</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Claude</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Gemini</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Grok</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Perplexity</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">DeepSeek</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Midjourney</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Nano Banana</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Seedance</span>
          <span class="ai-tool-dot"></span>
          <span class="ai-tool">Antigravity</span>
          <span class="ai-tool-dot"></span>
        </div>
      </div>
    </div>

    <!-- Raptor -->
    <section class="raptor-section">
      <div class="container">
        <div class="raptor-image-wrap">
          <img
            src="/images/raptor3evolution.jpg"
            alt="SpaceX Raptor motor evolutie — drie generaties, steeds minder onderdelen"
            loading="lazy"
          />
        </div>
        <div class="raptor-content">
          <blockquote class="raptor-quote">
            <p>"The best part is no part. The best process is no process."</p>
            <footer>— Elon Musk</footer>
          </blockquote>
          <p class="raptor-context">
            Drie generaties Raptor. Elke iteratie: minder onderdelen, meer kracht. Dat is ook onze aanpak.
          </p>
        </div>
      </div>
    </section>

    <!-- Zo werken wij -->
    <section class="how-section">
      <div class="container">
        <div class="section-label">Hoe wij werken</div>
        <h2 class="section-title">Eén systeem. Geen ruis.</h2>
        <div class="how-grid">
          <div class="how-card">
            <div class="how-number">01</div>
            <h3>Richting</h3>
            <p>We bepalen waar zichtbaarheid waarde heeft — en waar je moet stoppen met energie verspillen.</p>
          </div>
          <div class="how-card">
            <div class="how-number">02</div>
            <h3>Uitvoering</h3>
            <p>Van SEO tot AI-vindbaarheid: we bouwen wat werkt en strippen wat niet werkt. Geen bloat, geen bijvulling.</p>
          </div>
          <div class="how-card">
            <div class="how-number">03</div>
            <h3>Groei</h3>
            <p>Eén systeem dat schaalbaar is, zonder dat je een marketingafdeling nodig hebt.</p>
          </div>
        </div>
        <div class="how-cta">
          <a href="/services/" class="btn-secondary">Bekijk onze aanpak →</a>
        </div>
      </div>
    </section>

    <!-- Waarom MS618 -->
    <section class="why-section">
      <div class="container">
        <div class="section-label">Waarom MS618</div>
        <h2 class="section-title">Internationale expertise. Lokale impact.</h2>
        <div class="why-grid">
          <div class="why-content">
            <p>MS618 is geen gewoon bureau. Ons team opereert aan beide kanten van de oceaan. In de VS werken we met startups, scale-ups en private equity. In Silicon Valley, waar de technologie ontstaat die morgen jouw markt verandert.</p>
            <p>In Nederland zetten we diezelfde kennis, tooling en snelheid in voor MKB-ondernemers. Bedrijven die willen groeien maar geen marketingafdeling hebben. Die weten dat er iets moet veranderen maar niet precies wat.</p>
            <p class="why-tagline">Geen leverancier. Een partner.</p>
          </div>
          <aside class="why-quote">
            <p>Dat is waar wij in geloven: de beste technologie en strategie ter wereld hoort niet exclusief bij bedrijven met miljoenenbudgetten.</p>
            <p>De MKB-ondernemer die met ons werkt, krijgt toegang tot hetzelfde niveau. Dezelfde modellen. Dezelfde aanpak. Dezelfde ambitie.</p>
          </aside>
        </div>
      </div>
    </section>

    <!-- Client Logos -->
    <section class="clients-section">
      <div class="container">
        <div class="section-label">Vertrouwd door</div>
        <div class="clients-grid">
          <span class="client-logo">Inspecto Visio</span>
          <span class="client-logo">NDO-Nederland</span>
          <span class="client-logo">KIS Group</span>
          <span class="client-logo">Fugro</span>
          <span class="client-logo">Christmas Brothers</span>
          <span class="client-logo">STEP2</span>
          <span class="client-logo">Swoop</span>
          <span class="client-logo">Moovs</span>
          <span class="client-logo">Bedrijfskleding Online</span>
          <span class="client-logo">ZONklaar</span>
          <span class="client-logo">Hoekstra & Partners</span>
          <span class="client-logo">Friesland Boating</span>
          <span class="client-logo">Holtara</span>
          <span class="client-logo">Hout Met Historie</span>
          <span class="client-logo">DVM</span>
          <span class="client-logo">Waimakers</span>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="team-section" id="team">
      <div class="container">
        <div class="section-label">Het team</div>
        <h2 class="section-title">Vijf specialisten. Geen juniors. Geen ruis.</h2>
        <p class="section-sub">Wij worden betrokken wanneer marketing versnipperd raakt, tooling de regie overneemt, of zichtbaarheid geen groei meer oplevert. Ervaring telt wanneer versnelling inzet.</p>
        <div class="team-grid">
          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jorrit Miedema</h3>
              <span class="member-role">Strategie, SEO & AI</span>
              <span class="member-edu">BSc, Information Technology</span>
              <p>12+ jaar groei-ervaring. Ex full-service agency eigenaar. AI-first sinds vóór ChatGPT.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jurjan Groothuis</h3>
              <span class="member-role">Ads-expert</span>
              <span class="member-edu">MSc, International Management</span>
              <p>12+ jaar ervaring in performance advertising. Werkte bij Google HQ Dublin.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">P</div>
            <div class="member-info">
              <h3>Peter Ydel</h3>
              <span class="member-role">Lead designer</span>
              <span class="member-edu">BSc, UX & Design</span>
              <p>Ontwikkelde campagnes en visuele concepten voor internationale merken.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">R</div>
            <div class="member-info">
              <h3>Ramin Schultz</h3>
              <span class="member-role">Growth hacker (Los Angeles)</span>
              <span class="member-edu">BSc, Information Management</span>
              <p>Silicon Valley-ervaring. Werkte voor Nike, Uber en diverse startups en scale-ups.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">W</div>
            <div class="member-info">
              <h3>Wouter van Haaften</h3>
              <span class="member-role">AI-strategie</span>
              <span class="member-edu">MSc, Information Management</span>
              <p>Vertaalt complexe AI-technologie naar heldere, toepasbare oplossingen.</p>
            </div>
          </div>
        </div>
      </div>
    </section>



    <!-- Testimonials -->
    <section class="testimonials-section">
      <div class="container">
        <div class="section-label">Wat klanten zeggen</div>
        <div class="testimonials-grid">
          <blockquote class="testimonial">
            <p>"MS618 bracht structuur in onze wildgroei aan marketinginitiatieven. Binnen 6 maanden verdrievoudigden we ons organisch verkeer — en meer dan dat: we wisten eindelijk waaróm het werkte."</p>
            <footer>
              <strong>Thomas W.</strong>
              <span>CMO, SaaS Scale-up</span>
            </footer>
          </blockquote>
          <blockquote class="testimonial">
            <p>"Wij zijn een nichebedrijf in technische oplossingen. MS618 begreep onze markt meteen en positioneerde ons als de autoriteit in ons segment. LinkedIn-leads stegen met 180% in het eerste jaar."</p>
            <footer>
              <strong>Anke M.</strong>
              <span>Directeur, Technisch adviesbureau</span>
            </footer>
          </blockquote>
          <blockquote class="testimonial">
            <p>"Geen bullshit, geen vage rapporten. MS618 koppelt elke actie aan een meetbaar resultaat. Dat is precies wat wij als data-gedreven organisatie nodig hebben."</p>
            <footer>
              <strong>Peter L.</strong>
              <span>CEO, E-commerce Scale-up</span>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Latest Blog Posts -->
    {recentPosts.length > 0 && (
      <section class="blog-section">
        <div class="container">
          <div class="section-header">
            <div>
              <div class="section-label">Kennis & inzichten</div>
              <h2 class="section-title">Laatste artikelen</h2>
            </div>
            <a href="/blog/" class="btn-secondary">Alle artikelen →</a>
          </div>
          <div class="blog-grid">
            {recentPosts.map((post) => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                slug={post.id}
                publishDate={post.data.publishDate}
                category={post.data.category}
                author={post.data.author}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <CTA />

  </main>
  <Footer />
</Base>

<style>
  /* ── Section labels ── */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 0.75rem;
  }

  .section-label::before {
    content: '';
    width: 1.5rem;
    height: 1px;
    background: #444;
  }

  .section-title {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #fafafa;
  }

  .section-sub {
    font-size: 0.9375rem;
    color: #666;
    max-width: 480px;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  /* ── Award bar ── */
  .award-bar {
    border-bottom: 1px solid #1a1a1a;
    background: #0d0d0d;
    padding: 0.75rem 0;
  }

  .award-inner {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .award-google-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #888;
    letter-spacing: -0.01em;
  }

  .award-divider {
    display: block;
    width: 1px;
    height: 1rem;
    background: #333;
  }

  .award-text {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #888;
    letter-spacing: 0.01em;
  }

  .award-dot {
    color: #333;
    font-size: 0.875rem;
  }

  .award-sub {
    font-size: 0.8125rem;
    color: #555;
  }

  /* ── Problem ── */
  .problem-section {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 6rem 0;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 2rem;
  }

  .problem-col h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #fafafa;
    margin-bottom: 1.25rem;
  }

  .problem-col p {
    color: #666;
    line-height: 1.65;
    margin-bottom: 0.875rem;
    font-size: 0.9375rem;
  }

  .problem-col-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .problem-stat {
    padding: 1.25rem 1.5rem;
    background: #0f0f0f;
    border: 1px solid #1a1a1a;
  }

  .pstat-number {
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: #fafafa;
    margin-bottom: 0.375rem;
  }

  .pstat-text {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.5;
  }

  .problem-manifesto {
    color: #888 !important;
    font-size: 0.9375rem !important;
    line-height: 1.7 !important;
    border-left: 2px solid #2a2a2a;
    padding-left: 1rem;
    margin-top: 1.5rem;
  }

  .problem-conclusion {
    color: #fafafa !important;
    font-size: 1rem !important;
    font-weight: 500;
    margin-top: 1.5rem;
  }

  /* ── Why MS618 ── */
  .why-section {
    background: #0d0d0d;
    border-top: 1px solid #1a1a1a;
    padding: 6rem 0;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 2rem;
    align-items: start;
  }

  .why-content p {
    font-size: 0.9375rem;
    color: #666;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .why-tagline {
    color: #fafafa !important;
    font-weight: 500;
    font-size: 1rem !important;
    margin-top: 1.5rem;
  }

  .why-quote {
    border-left: 2px solid #333;
    padding-left: 1.5rem;
  }

  .why-quote p {
    font-size: 0.9375rem;
    color: #777;
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ── Clients ── */
  .clients-section {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 4rem 0;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem 2rem;
    margin-top: 1.5rem;
  }

  .client-logo {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #444;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .client-logo:hover {
    color: #666;
  }

  @media (max-width: 1024px) {
    .clients-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .clients-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem 1.5rem;
    }
    
    .client-logo {
      font-size: 0.875rem;
    }
  }

  /* ── AI Tools Bar ── */
  .ai-tools-bar {
    border-top: 1px solid #1a1a1a;
    border-bottom: 1px solid #1a1a1a;
    background: #0d0d0d;
    padding: 2.5rem 0 3rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .ai-tools-label {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #666;
    margin-bottom: 0.25rem;
  }

  .ai-tools-subtitle {
    font-size: 0.8125rem;
    color: #555;
    max-width: 480px;
    margin: 0 auto 2rem;
    line-height: 1.5;
  }

  .ai-tools-marquee {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
  }

  .ai-tools-track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: scroll-ai-tools 120s linear infinite;
  }

  .ai-tools-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-ai-tools {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .ai-tool {
    font-size: 1rem;
    font-weight: 400;
    color: #444;
    letter-spacing: 0;
    white-space: nowrap;
    padding: 0 0.25rem;
    transition: color 0.3s ease;
    cursor: default;
  }

  .ai-tool:hover {
    color: #666;
  }

  .ai-tool-dot {
    width: 3px;
    height: 3px;
    background: #333;
    border-radius: 50%;
    flex-shrink: 0;
    margin: 0 1.25rem;
  }

  /* ── Raptor ── */
  .raptor-section {
    position: relative;
    border-top: 1px solid #1a1a1a;
    background: #0a0a0a;
    padding: 4rem 0;
  }

  .raptor-image-wrap {
    position: relative;
    max-width: 1000px;
    margin: 0 auto 3rem;
    border: 1px solid #1a1a1a;
    overflow: hidden;
  }

  .raptor-image-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  .raptor-overlay {
    display: none;
  }

  .raptor-content {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .raptor-quote {
    margin: 0 0 1.5rem;
    font-style: normal;
    padding: 0 1.5rem;
  }

  .raptor-quote-mark {
    display: none;
  }

  .raptor-quote p {
    font-size: 1.125rem;
    font-weight: 500;
    font-style: italic;
    color: #fafafa;
    line-height: 1.5;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }

  .raptor-quote footer {
    font-size: 0.75rem;
    color: #555;
