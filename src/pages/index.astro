---
// MS618 Website - Main Homepage
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import CTA from '@/components/CTA.astro';
import BlogCard from '@/components/BlogCard.astro';

import { getCollection } from 'astro:content';
import {
  buildOrganizationPiece,
  buildWebsitePiece,
  buildWebpagePiece,
  buildBreadcrumbPiece,
} from '@/utils/schema';
import site from '@/data/site.json';

const recentPosts = (await getCollection('blog'))
  .filter((p) => !p.data.noindex)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

// Homepage services strip (core services, by curated order)
const homeServices = (await getCollection('services'))
  .filter((s) => !s.data.noindex)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 6);

// Real cases with quote + photo for the proof section
const homeCases = (await getCollection('cases'))
  .filter((c) => !c.data.noindex && c.data.quote)
  .slice(0, 3);

const pageUrl = site.url + '/';
const breadcrumbs = [{ name: 'Home' }];

const schemaGraph = [
  buildOrganizationPiece(),
  buildWebsitePiece(),
  buildWebpagePiece(pageUrl, 'MS618 — AI Marketing Bureau voor B2B | Senior Specialisten', 'Geen juniorkoppels. Geen losse acties. MS618 combineert senior expertise met AI voor meetbare B2B-groei — van SEO en advertenties tot analytics.', breadcrumbs),
  buildBreadcrumbPiece(pageUrl, breadcrumbs),
];
---

<Base
  title="Richting in versnelling"
  seoTitle="AI-marketingbureau voor B2B-groei | Senior team | MS618"
  description="Wij nemen je complete online groei over: AI, SEO, advertenties en website. Senior specialisten, geen juniors, geen losse acties. Eén partner, geen marketingafdeling nodig."
  ogType="website"
  rss={true}
  schemaGraph={schemaGraph}
>
  <Header />
  <main id="main-content">

    <!-- Hero -->
    <Hero ctaSecondary={{ label: 'Bekijk cases', href: '/cases/' }} />

    <!-- Proof band: logos + reviews + award in one quiet strip -->
    <section class="clients-section proof-band" aria-label="Vertrouwd door klanten">
      <div class="container">
        <div class="section-label">Vertrouwd door</div>
        <div class="clients-grid">
          <div class="client-logo"><img src="/images/clients/inspecto-visio.png" alt="Inspecto Visio" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/ndo-nederland.png" alt="NDO Nederland" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/kis-group.png" alt="KIS Group" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/fugro.png" alt="Fugro" loading="lazy" /></div>
          <div class="client-logo client-logo--bright"><img src="/images/clients/christmas-brothers.svg" alt="Christmas Brothers" loading="lazy" /></div>
          <div class="client-logo client-logo--bright"><img src="/images/clients/step2.svg" alt="STEP2" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/swoop.png" alt="Swoop" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/moovs.png" alt="Moovs" loading="lazy" /></div>
          <div class="client-logo client-logo--bright"><img src="/images/clients/bedrijfskleding-online.webp" alt="Bedrijfskleding Online" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/zonklaar.svg" alt="ZONklaar" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/hoekstra-partners.png" alt="Hoekstra & Partners" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/friesland-boating.jpg" alt="Friesland Boating" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/holtara.svg" alt="Holtara" loading="lazy" /></div>
          <div class="client-logo"><img src="/images/clients/houtmethistorie.svg" alt="Hout Met Historie" loading="lazy" /></div>
          <div class="client-logo client-logo--bright"><img src="/images/clients/dvm.svg" alt="DVM" loading="lazy" /></div>
        </div>
        <p class="proof-trust">
          <span class="proof-item"><span class="proof-star" aria-hidden="true">★</span> 5,0 op Google · 21 reviews</span>
          <span class="proof-sep" aria-hidden="true">·</span>
          <a class="proof-item proof-link" href="/blog/google-ads-impact-awards-2026/">Genomineerd: Google Ads Impact Awards 2026</a>
        </p>
      </div>
    </section>

    <!-- Problem -->
    <section class="problem-section" id="aanpak">
      <div class="container">
        <div class="section-label">Het probleem</div>
        <div class="problem-grid">
          <div class="problem-col">
            <h2>Je weet dat je iets moet.<br>Maar wat?</h2>
            <p>AI is overal. Je concurrent maakt er al websites mee, advertenties, content. Ondertussen vraag je je af: moet ik een nieuwe website? Wat kan ik eigenlijk met ChatGPT? En waarom levert mijn marketing geen klanten meer op?</p>
            <p>Het probleem is niet dat je te weinig doet. Het probleem is dat niemand je vertelt wat je wél moet doen — en wat je gerust kunt laten.</p>
            <p class="problem-manifesto">Je zoekt klanten. Niet meer tools.<br>Je zoekt groei. Niet meer kanalen.<br>Je zoekt iemand die het regelt. Niet iemand die een rapport stuurt.</p>
            <p class="problem-conclusion"><span class="gold-sheen">Dat is precies wat wij doen.</span></p>
          </div>
          <div class="problem-col problem-col-right">
            <div class="problem-stat">
              <div class="pstat-number">9 van de 10</div>
              <div class="pstat-text">MKB-bedrijven weten dat ze iets moeten met AI en online. Maar niet wat.</div>
            </div>
            <div class="problem-stat">
              <div class="pstat-number">0 FTE</div>
              <div class="pstat-text">Zoveel marketingmensen heb je nodig. Wij combineren strategie met AI zodat jij geen team hoeft te bouwen.</div>
            </div>
            <div class="problem-stat">
              <div class="pstat-number">1 partner</div>
              <div class="pstat-text">Die AI begrijpt, jouw markt kent, en het gewoon regelt. Meer heb je niet nodig.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Tools -->
    <div class="ai-tools-bar">
      <div class="container">
        <p class="ai-tools-label">De AI-modellen die wij inzetten voor jouw bedrijf</p>
        <p class="ai-tools-subtitle">Wij selecteren, combineren en implementeren de beste AI voor jouw situatie. Jij krijgt het resultaat, wij regelen de techniek.</p>
      </div>
      <div class="ai-tools-static">
        <span class="ai-tool">Gemini</span>
        <span class="ai-tool">Grok</span>
        <span class="ai-tool">Perplexity</span>
        <span class="ai-tool">DeepSeek</span>
        <span class="ai-tool">Midjourney</span>
        <span class="ai-tool">Seedance</span>
        <span class="ai-tool">Nano Banana</span>
        <span class="ai-tool">ChatGPT</span>
        <span class="ai-tool">Antigravity</span>
        <span class="ai-tool ai-tool-claude" data-claude>Claude</span>
        <span class="claude-streak"></span>
      </div>
    </div>

    <script>
      function initStreak(container) {
        const streak = container.querySelector('.claude-streak');
        const claude = container.querySelector('[data-claude]');
        const tools = container.querySelectorAll('.ai-tool');
        if (!streak || !claude) return;

        function moveTo(el) {
          const parentRect = container.getBoundingClientRect();
          const elRect = el.getBoundingClientRect();
          streak.style.left = (elRect.left - parentRect.left + elRect.width / 2) + 'px';
          streak.style.top = (elRect.bottom - parentRect.top + 4) + 'px';
          streak.style.width = (elRect.width * 1) + 'px';
        }

        moveTo(claude);

        tools.forEach(tool => {
          tool.addEventListener('mouseenter', () => moveTo(tool));
        });

        container.addEventListener('mouseleave', () => moveTo(claude));
        window.addEventListener('resize', () => moveTo(claude));
      }

      document.querySelectorAll('.ai-tools-static').forEach(initStreak);
    </script>

    <!-- Diensten -->
    <section class="services-strip">
      <div class="container">
        <div class="section-header">
          <div>
            <div class="section-label">Diensten</div>
            <h2 class="section-title">Wat wij voor je regelen</h2>
          </div>
          <a href="/diensten/" class="btn-secondary">Alle diensten →</a>
        </div>
        <div class="svc-grid">
          {homeServices.map((s) => (
            <a class="svc-card" href={`/diensten/${s.id}/`}>
              <span class="svc-title">{s.data.title}</span>
              <span class="svc-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Raptor -->
    <section class="raptor-section">
      <div class="container">
        <div class="raptor-image-wrap">
          <img
            src="/images/raptor3evolution.jpg"
            alt="SpaceX Raptor motor evolutie — drie generaties, steeds minder onderdelen"
            width="1456"
            height="915"
            loading="lazy"
          />
        </div>
        <div class="raptor-content">
          <blockquote class="raptor-quote">
            <p>"The best part is no part. The best process is no process."</p>
            <footer>— Elon Musk</footer>
          </blockquote>
          <p class="raptor-context">
            Drie generaties Raptor. Elke iteratie: minder onderdelen, meer kracht. Dat is ook onze aanpak.
          </p>
        </div>
      </div>
    </section>

    <!-- Zo werken wij -->
    <section class="how-section">
      <div class="container">
        <div class="section-label">Hoe wij werken</div>
        <h2 class="section-title">Eén systeem. Geen ruis.</h2>
        <div class="how-grid">
          <div class="how-card">
            <div class="how-number">01</div>
            <h3>Richting</h3>
            <p>We bepalen waar zichtbaarheid waarde heeft — en waar je moet stoppen met energie verspillen.</p>
          </div>
          <div class="how-card">
            <div class="how-number">02</div>
            <h3>Uitvoering</h3>
            <p>Van SEO tot AI-vindbaarheid: we bouwen wat werkt en strippen wat niet werkt. Geen bloat, geen bijvulling.</p>
          </div>
          <div class="how-card">
            <div class="how-number">03</div>
            <h3>Groei</h3>
            <p>Eén systeem dat schaalbaar is, zonder dat je een marketingafdeling nodig hebt.</p>
          </div>
        </div>
        <div class="how-cta">
          <a href="/diensten/" class="btn-secondary">Bekijk onze aanpak →</a>
        </div>
      </div>
    </section>

    <!-- Waarom MS618 -->
    <section class="why-section">
      <div class="container">
        <div class="section-label">Waarom MS618</div>
        <h2 class="section-title">Internationale expertise. Lokale impact.</h2>
        <div class="why-grid">
          <div class="why-content">
            <p>Ons team opereert aan beide kanten van de oceaan. In de VS werken we met startups, scale-ups en private equity. In Silicon Valley, waar de technologie ontstaat die morgen jouw markt verandert.</p>
            <p>In Nederland zetten we diezelfde kennis, tooling en snelheid in voor MKB-ondernemers. Bedrijven die willen groeien maar geen marketingafdeling hebben. Die weten dat er iets moet veranderen maar niet precies wat.</p>
            <p class="why-tagline">Geen leverancier. Een partner.</p>
          </div>
          <aside class="why-quote">
            <p>Dat is waar wij in geloven: de beste technologie en strategie ter wereld hoort niet exclusief bij bedrijven met miljoenenbudgetten.</p>
            <p>De MKB-ondernemer die met ons werkt, krijgt toegang tot hetzelfde niveau. Dezelfde modellen. Dezelfde aanpak. Dezelfde ambitie.</p>
          </aside>
        </div>
      </div>
    </section>

    <!-- Echte cases (quote + foto + link) -->
    <section class="testimonials-section cases-home">
      <div class="container">
        <div class="section-header">
          <div>
            <div class="section-label">Echte cases</div>
            <h2 class="section-title">Echte klanten, in hun eigen woorden</h2>
          </div>
          <a href="/cases/" class="btn-secondary">Alle cases →</a>
        </div>
        <div class="testimonials-grid">
          {homeCases.map((c) => (
            <a class="testimonial case-tile" href={`/cases/${c.id}/`}>
              <div class="case-tile-head">
                {c.data.quotePhoto && (
                  <img src={c.data.quotePhoto} alt={c.data.quoteName} width="44" height="44" loading="lazy" />
                )}
                <div class="case-tile-who">
                  <strong>{c.data.quoteName}</strong>
                  <span>{c.data.quoteRole}</span>
                </div>
              </div>
              <p class="case-tile-quote">"{c.data.quote}"</p>
              <div class="case-tile-foot">
                <span class="case-tile-result">{c.data.result}</span>
                <span class="case-tile-link">Lees de case →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="team-section" id="team">
      <div class="container">
        <div class="section-label">Het team</div>
        <h2 class="section-title">Vijf specialisten. Geen juniors. Geen ruis.</h2>
        <p class="section-sub">Wij worden betrokken wanneer marketing versnipperd raakt, tooling de regie overneemt, of zichtbaarheid geen groei meer oplevert. Ervaring telt wanneer versnelling inzet.</p>
        <div class="team-grid">
          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jorrit Miedema</h3>
              <span class="member-role">Strategie, SEO & AI</span>
              <span class="member-edu">BSc, Information Technology</span>
              <p>12+ jaar groei-ervaring. Ex full-service agency eigenaar. AI-first sinds vóór ChatGPT.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">J</div>
            <div class="member-info">
              <h3>Jurjan Groothuis</h3>
              <span class="member-role">Ads-expert</span>
              <span class="member-edu">MSc, International Management</span>
              <p>12+ jaar ervaring in performance advertising. Werkte bij Google HQ Dublin.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">P</div>
            <div class="member-info">
              <h3>Peter Ydel</h3>
              <span class="member-role">Lead designer</span>
              <span class="member-edu">BSc, UX & Design</span>
              <p>Ontwikkelde campagnes en visuele concepten voor internationale merken.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">R</div>
            <div class="member-info">
              <h3>Ramin Schultz</h3>
              <span class="member-role">Growth hacker (Los Angeles)</span>
              <span class="member-edu">BSc, Information Management</span>
              <p>Silicon Valley-ervaring. Werkte voor Nike, Uber en diverse startups en scale-ups.</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar">W</div>
            <div class="member-info">
              <h3>Wouter van Haaften</h3>
              <span class="member-role">AI-strategie</span>
              <span class="member-edu">MSc, Information Management</span>
              <p>Vertaalt complexe AI-technologie naar heldere, toepasbare oplossingen.</p>
            </div>
          </div>
        </div>
      </div>
    </section>




    <!-- Latest Blog Posts -->
    {recentPosts.length > 0 && (
      <section class="blog-section">
        <div class="container">
          <div class="section-header">
            <div>
              <div class="section-label">Kennis & inzichten</div>
              <h2 class="section-title">Laatste artikelen</h2>
            </div>
            <a href="/blog/" class="btn-secondary">Alle artikelen →</a>
          </div>
          <div class="blog-grid">
            {recentPosts.map((post) => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                slug={post.id}
                publishDate={post.data.publishDate}
                category={post.data.category}
                author={post.data.author}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <CTA />

    <!-- .618 signatuur -->
    <div class="sig-618">
      <a href="/fibonacci/">
        <span class="sig-num gold-sheen">.618</span>
        <span class="sig-text">De gulden snede achter onze naam →</span>
      </a>
    </div>

  </main>

  <script>
    // Restrained scroll-reveal; skipped entirely for reduced-motion users.
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
      const targets = document.querySelectorAll('main > section:not(.hero), main > .ai-tools-bar, main > .sig-618');
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        }
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
      targets.forEach((el) => {
        el.classList.add('reveal');
        io.observe(el);
      });
    }
  </script>
  <Footer />
</Base>

<style>
  /* ── Section labels ── */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8a8a;
    margin-bottom: 0.75rem;
  }

  .section-label::before {
    content: '';
    width: 1.5rem;
    height: 1px;
    background: #444;
  }

  .section-title {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #fafafa;
  }

  .section-sub {
    font-size: 0.9375rem;
    color: #999999;
    max-width: 480px;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  /* ── Award bar ── */
  .award-bar {
    display: block;
    border-bottom: 1px solid #1a1a1a;
    background: #0d0d0d;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
  }

  .award-inner {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .award-google-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #a3a3a3;
    letter-spacing: -0.01em;
  }

  .award-divider {
    display: block;
    width: 1px;
    height: 1rem;
    background: #333;
  }

  .award-text {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #a3a3a3;
    letter-spacing: 0.01em;
  }

  .award-dot {
    color: #333;
    font-size: 0.875rem;
  }

  .award-sub {
    font-size: 0.8125rem;
    color: #8a8a8a;
  }

  /* ── Problem ── */
  .problem-section {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 6rem 0;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 2rem;
  }

  .problem-col h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #fafafa;
    margin-bottom: 1.25rem;
  }

  .problem-col p {
    color: #999999;
    line-height: 1.65;
    margin-bottom: 0.875rem;
    font-size: 0.9375rem;
  }

  .problem-col-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .problem-stat {
    padding: 1.25rem 1.5rem;
    background: #0f0f0f;
    border: 1px solid #1a1a1a;
  }

  .pstat-number {
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: #fafafa;
    margin-bottom: 0.375rem;
  }

  .pstat-text {
    font-size: 0.8125rem;
    color: #999999;
    line-height: 1.5;
  }

  /* Editorial display moment: the manifesto carries the page's voice */
  .problem-manifesto {
    color: #d4d4d4 !important;
    font-size: clamp(1.125rem, 1.8vw, 1.375rem) !important;
    font-weight: 500;
    line-height: 1.55 !important;
    letter-spacing: -0.01em;
    border-left: 2px solid #2a2a2a;
    padding-left: 1.25rem;
    margin-top: 2rem;
  }

  .problem-conclusion {
    color: #fafafa !important;
    font-size: 1.0625rem !important;
    font-weight: 600;
    margin-top: 1.5rem;
  }

  /* ── Why MS618 ── */
  .why-section {
    background: #0d0d0d;
    border-top: 1px solid #1a1a1a;
    padding: 6rem 0;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-top: 2rem;
    align-items: start;
  }

  .why-content p {
    font-size: 0.9375rem;
    color: #999999;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .why-tagline {
    color: #fafafa !important;
    font-weight: 500;
    font-size: 1rem !important;
    margin-top: 1.5rem;
  }

  .why-quote {
    border-left: 2px solid #333;
    padding-left: 1.5rem;
  }

  .why-quote p {
    font-size: 0.9375rem;
    color: #9e9e9e;
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ── Clients ── */
  .clients-section {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 4rem 0;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2.5rem 4rem;
    margin-top: 2rem;
    align-items: center;
  }

  .client-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 32px;
  }

  .client-logo img {
    max-width: 140px;
    max-height: 36px;
    width: auto;
    height: auto;
    object-fit: contain;
    /* grayscale+invert handles both transparent-bg and white-bg PNGs:
       white bg gets inverted to black → blends into dark page;
       dark artwork gets inverted to light → readable */
    filter: grayscale(100%) invert(1) brightness(0.95) contrast(1.05);
    opacity: 0.85;
