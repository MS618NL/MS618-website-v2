---
import { getLangFromUrl, getAlternatePath, useTranslations } from '@/i18n';

interface Props {
  url?: URL;
}

const url = Astro.props.url ?? Astro.url;
const lang = getLangFromUrl(url);
const t = useTranslations(lang);
const altLang = lang === 'nl' ? 'en' : 'nl';
const altPath = getAlternatePath(url, altLang);
const prefix = lang === 'en' ? '/en' : '';
const homeHref = lang === 'en' ? '/en/' : '/';

const navItems = [
  { label: t('nav.services'), href: `${prefix}/services/` },
  { label: t('nav.cases'), href: `${prefix}/cases/` },
  { label: t('nav.blog'), href: `${prefix}/blog/` },
  { label: t('nav.about'), href: `${prefix}/about/` },
];
const contactHref = `${prefix}/contact/`;
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href={homeHref} class="logo" aria-label="MS618 — Home">
      <span class="logo-text">MS618</span>
    </a>

    <nav class="main-nav" aria-label={lang === 'en' ? 'Main navigation' : 'Hoofdnavigatie'}>
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <a href={altPath} class="lang-toggle" aria-label={`Switch to ${altLang.toUpperCase()}`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        {altLang.toUpperCase()}
      </a>
      <a href={contactHref} class="btn-primary header-cta">{t('nav.cta')}</a>
    </div>

    <button class="mobile-menu-toggle" id="mobile-toggle" aria-label={lang === 'en' ? 'Open menu' : 'Menu openen'} aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="mobile-nav-link">{item.label}</a>
        </li>
      ))}
      <li><a href={contactHref} class="mobile-nav-link mobile-cta">{t('nav.cta')} →</a></li>
      <li>
        <a href={altPath} class="mobile-nav-link lang-mobile">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          {altLang.toUpperCase()}
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 2.5rem;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    transition: background 0.5s ease, border-color 0.5s ease, backdrop-filter 0.5s ease;
  }

  .site-header.scrolled {
    background: rgba(10, 10, 10, 0.95);
    border-bottom: 1px solid #222;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 5rem;
  }

  .logo {
    flex-shrink: 0;
    text-decoration: none;
  }

  .logo-text {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fafafa;
  }

  .main-nav {
    flex: 1;
  }

  .main-nav ul {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 400;
    color: #888;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .nav-link:hover {
    opacity: 0.7;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #888;
    text-decoration: none;
    border: 1px solid #333;
    transition: opacity 0.2s ease;
  }

  .lang-toggle:hover {
    opacity: 0.7;
  }

  .header-cta {
    flex-shrink: 0;
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    background: #fafafa !important;
    color: #0a0a0a !important;
    border: none !important;
  }

  .header-cta:hover {
    opacity: 0.9;
    background: #fafafa !important;
    color: #0a0a0a !important;
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.75rem;
    margin-left: auto;
    min-width: 44px;
    min-height: 44px;
  }

  .mobile-menu-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: oklch(0.98 0 0);
    transition: all 0.2s ease;
  }

  .mobile-nav {
    display: none;
    border-top: 1px solid oklch(0.22 0 0);
    background: oklch(0.09 0 0);
    position: relative;
    z-index: 99;
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav-link {
    display: block;
    padding: 0.6rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: oklch(0.65 0 0);
    text-decoration: none;
    border-bottom: 1px solid oklch(0.15 0 0);
    transition: color 0.2s ease;
  }

  .mobile-nav-link:hover,
  .mobile-cta {
    color: oklch(0.98 0 0);
  }

  .lang-mobile {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: oklch(0.5 0 0) !important;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .site-header {
      top: 0;
    }

    .header-inner {
      height: 3.5rem;
    }

    .main-nav,
    .header-actions {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .mobile-nav.open {
      display: block;
    }

    .mobile-nav ul {
      padding: 0.75rem 1rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const header = document.getElementById('site-header');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('open');
    mobileNav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    mobileNav?.setAttribute('aria-hidden', String(isOpen));
  });

  // Scroll detection for transparent → blur nav
  function handleScroll() {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>
