---
import { getLangFromUrl, getAlternatePath, useTranslations } from '@/i18n';

interface Props {
  url?: URL;
  /** Override for the language-toggle target (e.g. when no translation of this page exists). */
  altPath?: string;
}

const url = Astro.props.url ?? Astro.url;
const lang = getLangFromUrl(url);
const t = useTranslations(lang);
const altLang = lang === 'nl' ? 'en' : 'nl';
const altPath = Astro.props.altPath ?? getAlternatePath(url, altLang);
const prefix = lang === 'en' ? '/en' : '';
const homeHref = lang === 'en' ? '/en/' : '/';

const navItems = [
  { label: t('nav.services'), href: lang === 'en' ? '/en/services/' : '/diensten/' },
  { label: t('nav.cases'), href: `${prefix}/cases/` },
  { label: t('nav.blog'), href: `${prefix}/blog/` },
  { label: t('nav.about'), href: `${prefix}/about/` },
  { label: 'Contact', href: `${prefix}/contact/` },
];
const contactHref = `${prefix}/contact/`;
---

<header class="site-header" id="site-header">
  <div class="header-bar">
    <div class="container header-inner">
      <a href={homeHref} class="logo" aria-label="MS618 — Home">
        <span class="logo-text">MS618</span>
      </a>

      <nav class="main-nav" aria-label={lang === 'en' ? 'Main navigation' : 'Hoofdnavigatie'}>
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="nav-link">{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="header-actions">
        <a href={altPath} class="lang-toggle" aria-label={`Switch to ${altLang.toUpperCase()}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          {altLang.toUpperCase()}
        </a>
        <a href={contactHref} class="btn-primary header-cta">{t('nav.cta')}</a>
      </div>

      <button class="mobile-menu-toggle" id="mobile-toggle" aria-label={lang === 'en' ? 'Open menu' : 'Menu openen'} aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-nav">
    <nav aria-label={lang === 'en' ? 'Mobile navigation' : 'Mobiele navigatie'}>
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="mobile-nav-link">{item.label}</a>
          </li>
        ))}
        <li><a href={contactHref} class="mobile-nav-link mobile-cta">{t('nav.cta')} →</a></li>
        <li>
          <a href={altPath} class="mobile-nav-link lang-mobile">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            {altLang.toUpperCase()}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* ── Fixed header shell ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 100;
  }

  /* ── Top bar (always visible) ── */
  .header-bar {
    background: transparent;
    border-bottom: none;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .site-header.scrolled .header-bar {
    background: rgba(10, 10, 10, 0.95);
    border-bottom: 1px solid #222;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 4rem;
  }

  .logo {
    flex-shrink: 0;
    text-decoration: none;
  }

  .logo-text {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fafafa;
  }

  .main-nav {
    flex: 1;
  }

  .main-nav ul {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 400;
    color: #a3a3a3;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .nav-link:hover {
    opacity: 0.7;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #a3a3a3;
    text-decoration: none;
    border: 1px solid #333;
    transition: opacity 0.2s ease;
  }

  .lang-toggle:hover {
    opacity: 0.7;
  }

  .header-cta {
    flex-shrink: 0;
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    background: #fafafa !important;
    color: #0a0a0a !important;
    border: none !important;
  }

  .header-cta:hover {
    opacity: 0.9;
    background: #fafafa !important;
    color: #0a0a0a !important;
  }

  /* ── Hamburger (hidden on desktop) ── */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.75rem;
    margin-left: auto;
    min-width: 44px;
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
  }

  .mobile-menu-toggle .bar {
    display: block;
    width: 20px;
    height: 2px;
    background: #fafafa;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Animate to X when open */
  .mobile-menu-toggle.active .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-menu-toggle.active .bar:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-toggle.active .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile nav panel (hidden on desktop) ── */
  .mobile-nav {
    display: none;
    background: rgba(10, 10, 10, 0.98);
    border-top: 1px solid #222;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .mobile-nav.open {
    display: block;
    max-height: 100vh;
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 1rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mobile-nav-link {
    display: block;
    padding: 0.875rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: #999;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 0.2s ease;
  }

  .mobile-nav-link:hover,
  .mobile-cta {
    color: #fafafa;
  }

  .lang-mobile {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #999999 !important;
    font-size: 0.875rem;
    border-bottom: none;
  }

  /* ── Desktop: top offset for floating effect ── */
  @media (min-width: 769px) {
    .site-header {
      top: 2rem;
    }

    .mobile-menu-toggle,
    .mobile-nav {
      display: none !important;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .header-inner {
      height: 3.5rem;
    }

    .logo-text {
      font-size: 1.25rem;
    }

    .main-nav,
    .header-actions {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    /* Always show background on mobile for readability */
    .header-bar {
      background: rgba(10, 10, 10, 0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    .mobile-nav ul {
      padding: 0.75rem 1rem 1rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const header = document.getElementById('site-header');

  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      const isOpen = mobileNav.classList.contains('open');

      if (isOpen) {
        // Close
        mobileNav.classList.remove('open');
        toggle.classList.remove('active');
        toggle.setAttribute('aria-expanded', 'false');
        mobileNav.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      } else {
        // Open
        mobileNav.classList.add('open');
        toggle.classList.add('active');
        toggle.setAttribute('aria-expanded', 'true');
        mobileNav.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
    });

    // Close on link click
    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileNav.classList.remove('open');
        toggle.classList.remove('active');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }

  // Scroll detection for transparent → blur nav
  function handleScroll() {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>
