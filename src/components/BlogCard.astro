---
import { formatDate } from '@/utils/seo';

interface Props {
  title: string;
  description: string;
  slug: string;
  publishDate: Date;
  category: string;
  author?: string;
}

const { title, description, slug, publishDate, category, author = 'MS618' } = Astro.props;
---

<article class="blog-card">
  <div class="card-meta">
    <span class="tag">{category}</span>
    <time datetime={publishDate.toISOString()} class="card-date">
      {formatDate(publishDate)}
    </time>
  </div>
  <h3 class="card-title">
    <a href={`/blog/${slug}/`}>{title}</a>
  </h3>
  <p class="card-desc">{description}</p>
  <a href={`/blog/${slug}/`} class="card-link">Lees meer →</a>
</article>

<style>
  .blog-card {
    border: 1px solid oklch(0.22 0 0);
    padding: 1.75rem;
    background: oklch(0.11 0 0);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s ease;
  }

  .blog-card:hover {
    border-color: oklch(0.3 0 0);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .card-date {
    font-size: 0.8125rem;
    color: oklch(0.4 0 0);
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .card-title a {
    color: oklch(0.98 0 0);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .card-title a:hover {
    color: oklch(0.75 0 0);
  }

  .card-desc {
    font-size: 0.9rem;
    color: oklch(0.5 0 0);
    line-height: 1.6;
    flex: 1;
  }

  .card-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: oklch(0.55 0 0);
    text-decoration: none;
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .card-link:hover {
    color: oklch(0.98 0 0);
  }
</style>
