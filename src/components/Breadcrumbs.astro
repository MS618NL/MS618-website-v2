---
interface BreadcrumbItem {
  name: string;
  item?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Broodkruimels">
  <ol>
    {items.map((crumb, i) => (
      <li>
        {i < items.length - 1 ? (
          <a href={crumb.item}>{crumb.name}</a>
        ) : (
          <span aria-current="page">{crumb.name}</span>
        )}
        {i < items.length - 1 && <span class="sep" aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    padding: 0.75rem 0;
  }

  ol {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  a {
    font-size: 0.8125rem;
    color: oklch(0.45 0 0);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: oklch(0.65 0 0);
  }

  span[aria-current="page"] {
    font-size: 0.8125rem;
    color: oklch(0.55 0 0);
  }

  .sep {
    font-size: 0.75rem;
    color: oklch(0.3 0 0);
    margin: 0 0.1rem;
  }
</style>
