---
interface Props {
  title: string;
  description: string;
  slug: string;
  client: string;
  service: string;
  result: string;
}

const { title, description, slug, client, service, result } = Astro.props;
---

<article class="case-card">
  <div class="card-meta">
    <span class="tag">{service}</span>
    <span class="card-client">{client}</span>
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  <div class="card-result">
    <span class="result-label">Resultaat</span>
    <span class="result-value">{result}</span>
  </div>
  <span class="card-link card-link--soon">Case volgt binnenkort</span>
</article>

<style>
  .case-card {
    border: 1px solid oklch(0.22 0 0);
    padding: 1.75rem;
    background: oklch(0.11 0 0);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s ease;
  }

  .case-card:hover {
    border-color: oklch(0.3 0 0);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .card-client {
    font-size: 0.8125rem;
    color: oklch(0.4 0 0);
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.9rem;
    color: oklch(0.5 0 0);
    line-height: 1.6;
    flex: 1;
  }

  .card-result {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem;
    background: oklch(0.09 0 0);
    border: 1px solid oklch(0.18 0 0);
    margin-top: 0.25rem;
  }

  .result-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: oklch(0.4 0 0);
  }

  .result-value {
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(0.72 0.18 145);
  }

  .card-link--soon {
    font-size: 0.8125rem;
    color: oklch(0.35 0 0);
    font-style: italic;
    cursor: default;
  }
</style>
